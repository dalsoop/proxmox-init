#!/usr/bin/env bash
# pxi-seo-monitor — Prelik SEO Monitor (LXC 50183, prelik-seo-monitor.50.internal.kr) 관리 CLI
# Laravel 12 + Livewire SEO 분석 앱 + 내장 Playwright (docker/ + tests/ 모노레포 스타일)
# 템플릿: /usr/local/share/pxi-seo-monitor/ (testkube 구조 미러)
# 공통 수명관리는 pxi-laravel 에 위임.
set -euo pipefail

SHARE_DIR="/usr/local/share/pxi-seo-monitor"

VMID="${SEO_VMID:-50183}"
APP_ROOT="/var/www/html"
DB_NAME="ranode_seo"   # legacy DB 이름 유지 (마이그레이션 비용 회피)
DEFAULT_EMAIL="${SEO_DEFAULT_EMAIL:-tex02@naver.com}"
PLAYWRIGHT_ROOT="/opt/playwright"
PLAYWRIGHT_DOCKER_DIR="$PLAYWRIGHT_ROOT/docker"
PLAYWRIGHT_TESTS_DIR="$PLAYWRIGHT_ROOT/tests"
PLAYWRIGHT_PORT="${SEO_PLAYWRIGHT_PORT:-3000}"
ARTIFACTS_ROOT="/mnt/seo-artifacts"
NAS_HOST_PATH="/mnt/synology/works-nfs/e2e/prelik-seo-monitor/playwright"

c_r(){ printf '\033[0;31m%s\033[0m' "$*"; }
c_g(){ printf '\033[0;32m%s\033[0m' "$*"; }
c_b(){ printf '\033[0;34m%s\033[0m' "$*"; }
c_y(){ printf '\033[0;33m%s\033[0m' "$*"; }
ok()   { echo "$(c_g '✓') $*" >&2; }
warn() { echo "$(c_y '⚠') $*" >&2; }
die()  { echo "$(c_r '✗') $*" >&2; exit 1; }
log()  { echo "$(c_b '[seo-monitor]') $*" >&2; }

in_lxc()  { pct exec "$VMID" -- bash -lc "$*"; }
artisan() { in_lxc "cd $APP_ROOT && php artisan $*"; }

require_up() {
  pct config "$VMID" >/dev/null 2>&1 || die "LXC $VMID (seo) 없음"
  [ "$(pct status "$VMID" 2>/dev/null | awk '{print $2}')" = "running" ] \
    || die "LXC $VMID 중지됨. pct start $VMID"
}

# ── sites ──────────────────────────────────────────────────────────────────
cmd_sites_list() {
  require_up
  in_lxc "mariadb $DB_NAME -e 'SELECT id, url, name, email, schedule_time, is_active, latest_score, last_analyzed_at FROM sites ORDER BY id;'"
}

sql_escape() { printf "%s" "$1" | sed "s/'/''/g"; }

cmd_sites_add() {
  require_up
  local url="" name="" email="$DEFAULT_EMAIL" schedule="08:00"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url)      url="$2"; shift 2 ;;
      --name)     name="$2"; shift 2 ;;
      --email)    email="$2"; shift 2 ;;
      --schedule) schedule="$2"; shift 2 ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  [[ -n "$url" ]] || die "--url 필요"

  local e_url e_name e_email e_sched
  e_url="$(sql_escape "$url")"
  e_name="$(sql_escape "$name")"
  e_email="$(sql_escape "$email")"
  e_sched="$(sql_escape "$schedule")"

  local name_val="NULL"
  [[ -n "$name" ]] && name_val="'$e_name'"

  in_lxc "mariadb $DB_NAME -e \"
    INSERT INTO sites (url, name, email, schedule_time, is_active, created_at, updated_at)
    VALUES ('$e_url', $name_val, '$e_email', '$e_sched', 1, NOW(), NOW())
    ON DUPLICATE KEY UPDATE
      name = COALESCE(VALUES(name), name),
      email = VALUES(email),
      schedule_time = VALUES(schedule_time),
      updated_at = NOW();
  \""
  ok "upsert: $url"
}

cmd_sites_delete() {
  require_up
  local id="${1:-}"; [[ -n "$id" ]] || die "사용법: sites delete <id>"
  in_lxc "mariadb $DB_NAME -e 'DELETE FROM analyses WHERE site_id=$id; DELETE FROM sites WHERE id=$id;'"
  ok "삭제: id=$id"
}

cmd_sites_activate() {
  require_up
  local id="${1:-}"; [[ -n "$id" ]] || die "사용법: sites activate <id>"
  in_lxc "mariadb $DB_NAME -e 'UPDATE sites SET is_active=1 WHERE id=$id;'"
  ok "활성화: id=$id"
}

cmd_sites_deactivate() {
  require_up
  local id="${1:-}"; [[ -n "$id" ]] || die "사용법: sites deactivate <id>"
  in_lxc "mariadb $DB_NAME -e 'UPDATE sites SET is_active=0 WHERE id=$id;'"
  ok "비활성화: id=$id"
}

cmd_sites_set_email() {
  require_up
  local id="${1:-}" email="${2:-}"
  [[ -n "$id" && -n "$email" ]] || die "사용법: sites set-email <id> <email>"
  local e_email; e_email="$(sql_escape "$email")"
  in_lxc "mariadb $DB_NAME -e \"UPDATE sites SET email='$e_email' WHERE id=$id;\""
  ok "id=$id → $email"
}

# ── 사이트 진입용 인증 (encrypted 저장) ─────────────────────────────────────
cmd_sites_auth() {
  require_up
  local action="${1:-show}"; shift || true
  local site_id="${1:-}"; shift || true
  [[ -n "$site_id" ]] || die "사용법: sites auth <show|set|clear> <id> [type] [creds]"
  case "$action" in
    show)  artisan "seo:auth show $site_id" ;;
    clear) artisan "seo:auth clear $site_id" ;;
    set)
      local type="${1:-}"; local creds="${2:-}"
      [[ -n "$type" && -n "$creds" ]] || die "사용법: sites auth set <id> <type> <creds>  (type: http_basic|wp_post_password|form)"
      # creds 를 안전하게 전달 (쉘 escape)
      in_lxc "cd $APP_ROOT && php artisan seo:auth set $site_id $type $(printf %q "$creds")"
      ;;
    *) die "action: show|set|clear" ;;
  esac
}

# ── WP 자동 디스커버리 (TSV: vmid<TAB>path<TAB>siteurl<TAB>blogname) ─────────
_wp_discover() {
  for v in $(pct list | awk 'NR>1 && $2=="running"{print $1}'); do
    pct exec "$v" -- bash -c '
      shopt -s nullglob
      for cfg in /var/www/*/wp-config.php /var/www/wp-config.php; do
        [ -f "$cfg" ] || continue
        p="$(dirname "$cfg")"
        db=$(awk -F"[\047\"]" "/^define.*DB_NAME/ {for(i=1;i<=NF;i++) if (\$i==\"DB_NAME\") {print \$(i+2); break}}" "$cfg")
        [ -n "$db" ] || continue
        url=$(mariadb -N -s -e "SELECT option_value FROM $db.wp_options WHERE option_name=\"siteurl\" LIMIT 1;" 2>/dev/null)
        name=$(mariadb -N -s -e "SELECT option_value FROM $db.wp_options WHERE option_name=\"blogname\" LIMIT 1;" 2>/dev/null)
        [ -n "$url" ] && printf "%s\t%s\t%s\n" "$p" "$url" "$name"
      done
    ' 2>/dev/null | while IFS= read -r line; do
      printf '%s\t%s\n' "$v" "$line"
    done
  done
}

cmd_sites_discover_wp() {
  printf '%-7s %-30s %-45s %s\n' VMID PATH SITEURL BLOGNAME
  _wp_discover | awk -F'\t' '{printf "%-7s %-30s %-45s %s\n", $1, $2, $3, $4}'
}

cmd_sites_import_wp() {
  require_up
  local dry_run="no" email="$DEFAULT_EMAIL"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run="yes"; shift ;;
      --email)   email="$2"; shift 2 ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done

  log "WP 사이트 수집 중..."
  local tmp; tmp="$(mktemp)"
  _wp_discover | tee "$tmp" | awk -F'\t' '{printf "  found: %s  (%s)\n", $3, $4}' >&2
  local count; count="$(wc -l <"$tmp")"
  [[ "$count" -eq 0 ]] && { rm -f "$tmp"; die "발견된 WP 사이트 없음"; }

  if [[ "$dry_run" == "yes" ]]; then
    warn "--dry-run: 실제 등록 생략"; rm -f "$tmp"; return 0
  fi

  log "seo 에 $count 개 사이트 upsert"
  while IFS=$'\t' read -r vmid path url name; do
    cmd_sites_add --url "$url" --name "$name" --email "$email"
  done <"$tmp"
  rm -f "$tmp"
  ok "import-wp 완료"
  echo >&2
  cmd_sites_list
}

# ── 분석/리포트 ─────────────────────────────────────────────────────────────
cmd_analyze() { require_up; artisan "seo:analyze ${1:-}"; }
cmd_report()  { require_up; artisan "seo:report  ${1:-}"; }

cmd_analyze_pages() {
  require_up
  local site_id="" limit="5" inc=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit)            limit="$2"; shift 2 ;;
      --include-homepage) inc="--include-homepage"; shift ;;
      *)                  site_id="$1"; shift ;;
    esac
  done
  artisan "seo:analyze-pages $site_id --limit=$limit $inc"
}

# ── 크롤러 (Guzzle BFS — pages 테이블 적재) ─────────────────────────────────
cmd_crawl() {
  require_up
  local site_id="" depth="2" max="50" timeout="15"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --depth)   depth="$2"; shift 2 ;;
      --max)     max="$2"; shift 2 ;;
      --timeout) timeout="$2"; shift 2 ;;
      *) site_id="$1"; shift ;;
    esac
  done
  artisan "seo:crawl $site_id --depth=$depth --max=$max --timeout=$timeout"
}

cmd_pages_list() {
  require_up
  local site_id="${1:-}"
  if [[ -n "$site_id" ]]; then
    in_lxc "mariadb $DB_NAME -e \"SELECT id, depth, status_code, fetch_ms, outbound_links, SUBSTRING(url,1,80) AS url, last_crawled_at FROM pages WHERE site_id=$site_id ORDER BY depth, id;\""
  else
    in_lxc "mariadb $DB_NAME -e 'SELECT s.id, s.url, COUNT(p.id) AS pages, MIN(p.depth) AS min_d, MAX(p.depth) AS max_d, MAX(p.last_crawled_at) AS last_crawl FROM sites s LEFT JOIN pages p ON p.site_id=s.id GROUP BY s.id, s.url ORDER BY s.id;'"
  fi
}

cmd_pages_clear() {
  require_up
  local site_id="${1:-}"; [[ -n "$site_id" ]] || die "사용법: pages clear <site_id>"
  in_lxc "mariadb $DB_NAME -e 'DELETE FROM pages WHERE site_id=$site_id;'"
  ok "site_id=$site_id 페이지 삭제"
}

# ── Hints (Sitebulb 스타일 집계 이슈) ───────────────────────────────────────
cmd_hints_list() {
  require_up
  local site_id="" severity="" analyzer="" top="20"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --severity) severity="$2"; shift 2 ;;
      --analyzer) analyzer="$2"; shift 2 ;;
      --top)      top="$2"; shift 2 ;;
      *)          site_id="$1"; shift ;;
    esac
  done
  local args="$site_id"
  [[ -n "$severity" ]] && args="$args --severity=$severity"
  [[ -n "$analyzer" ]] && args="$args --analyzer=$analyzer"
  [[ -n "$top"      ]] && args="$args --top=$top"
  artisan "seo:hints $args"
}

cmd_hints_materialize() {
  require_up
  artisan "seo:hints ${1:-} --materialize"
}

cmd_hints_clear() {
  require_up
  local site_id="${1:-}"
  if [[ -n "$site_id" ]]; then
    in_lxc "mariadb $DB_NAME -e 'DELETE FROM hints WHERE site_id=$site_id;'"
    ok "site_id=$site_id hints 삭제"
  else
    warn "전체 hints 삭제하려면: pxi-seo-monitor hints clear all"
  fi
}

# ── Links (broken / internal graph) ─────────────────────────────────────────
cmd_links_audit() {
  require_up
  local site_id="" limit="" ext="" force="" conc="8" timeout="10" days="7"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit)          limit="$2"; shift 2 ;;
      --limit=*)        limit="${1#*=}"; shift ;;
      --external-only)  ext="--external-only"; shift ;;
      --force)          force="--force"; shift ;;
      --concurrency)    conc="$2"; shift 2 ;;
      --concurrency=*)  conc="${1#*=}"; shift ;;
      --timeout)        timeout="$2"; shift 2 ;;
      --timeout=*)      timeout="${1#*=}"; shift ;;
      --recheck-days)   days="$2"; shift 2 ;;
      --recheck-days=*) days="${1#*=}"; shift ;;
      *)                site_id="$1"; shift ;;
    esac
  done
  local args="$site_id --concurrency=$conc --timeout=$timeout --recheck-days=$days"
  [[ -n "$limit" ]] && args="$args --limit=$limit"
  [[ -n "$ext"   ]] && args="$args $ext"
  [[ -n "$force" ]] && args="$args $force"
  artisan "seo:link-audit $args"
}

cmd_links_stats() {
  require_up
  local site_id="${1:-}"
  if [[ -n "$site_id" ]]; then
    in_lxc "mariadb $DB_NAME -e \"
      SELECT
        SUM(is_internal) AS internal_total,
        SUM(1 - is_internal) AS external_total,
        SUM(status_code BETWEEN 200 AND 299) AS ok_count,
        SUM(status_code >= 400) AS broken_count,
        SUM(checked_at IS NULL) AS unchecked
      FROM page_links WHERE site_id=$site_id;\""
  else
    in_lxc "mariadb $DB_NAME -e \"
      SELECT site_id,
        COUNT(*) AS total,
        SUM(is_internal) AS internal,
        SUM(status_code >= 400) AS broken,
        SUM(checked_at IS NULL) AS unchecked
      FROM page_links GROUP BY site_id ORDER BY site_id;\""
  fi
}

cmd_links_broken() {
  require_up
  local site_id="" type=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)   type="$2"; shift 2 ;;
      --type=*) type="${1#*=}"; shift ;;
      *)        site_id="$1"; shift ;;
    esac
  done
  [[ -n "$site_id" ]] || die "사용법: links broken <site_id> [--type internal|external|all]"
  local where="site_id=$site_id AND (status_code IS NULL AND checked_at IS NOT NULL OR status_code >= 400)"
  case "$type" in
    internal) where="$where AND is_internal=1" ;;
    external) where="$where AND is_internal=0" ;;
  esac
  in_lxc "mariadb $DB_NAME -e \"
    SELECT pl.id, pl.status_code AS st, IF(pl.is_internal,'int','ext') AS t,
           LEFT(p.url, 55) AS source_url, LEFT(pl.target_url, 80) AS target_url
    FROM page_links pl JOIN pages p ON p.id = pl.source_page_id
    WHERE $where ORDER BY pl.is_internal DESC, pl.status_code IS NULL, pl.status_code DESC LIMIT 200;\""
}

cmd_links_orphans() {
  require_up
  local site_id="${1:-}"; [[ -n "$site_id" ]] || die "사용법: links orphans <site_id>"
  in_lxc "mariadb $DB_NAME -e \"
    SELECT p.id, p.depth, LEFT(p.url, 90) AS url
    FROM pages p
    LEFT JOIN page_links pl ON pl.target_page_id = p.id AND pl.is_internal=1
    WHERE p.site_id=$site_id AND pl.id IS NULL
    GROUP BY p.id, p.depth, p.url
    ORDER BY p.depth, p.id LIMIT 100;\""
}

cmd_links_graph() {
  require_up
  local site_id="${1:-}"; [[ -n "$site_id" ]] || die "사용법: links graph <site_id>"
  artisan "tinker --execute=\"
    \\\$s = \\App\\Models\\Site::find($site_id);
    \\\$r = (new \\App\\Services\\Analyzers\\InternalLinkGraphAnalyzer)->analyze(\\\$s);
    echo 'score='.(\\\$r['score'] ?? '-').' total='.\\\$r['total_pages'].' orphans='.\\\$r['orphan_count'].' dead_ends='.\\\$r['dead_ends'].PHP_EOL;
    echo 'avg_inbound='.\\\$r['avg_inbound'].' avg_outbound='.\\\$r['avg_outbound'].PHP_EOL;
    echo 'top_pagerank:'.PHP_EOL;
    foreach (\\\$r['top_pagerank'] as \\\$t) {
        echo sprintf('  pr=%.4f in=%d out=%d %s'.PHP_EOL, \\\$t['pr'], \\\$t['inbound'], \\\$t['outbound'], \\\$t['url']);
    }\""
}

# ── Competitors ─────────────────────────────────────────────────────────────
cmd_competitors_list()    { require_up; artisan "seo:competitors list ${1:-}"; }
cmd_competitors_add() {
  require_up
  local parent="${1:-}"; shift || true
  [[ -n "$parent" ]] || die "사용법: competitors add <parent_site_id> --url <url> [--name <name>]"
  local url="" name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url|--url=*)   [[ "$1" == *=* ]] && url="${1#*=}"  || { url="$2";  shift; }; shift ;;
      --name|--name=*) [[ "$1" == *=* ]] && name="${1#*=}" || { name="$2"; shift; }; shift ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  [[ -n "$url" ]] || die "--url 필요"
  # Base64로 안전하게 전달
  local b64_url b64_name
  b64_url=$(printf '%s' "$url" | base64 -w0)
  local wrap="cd $APP_ROOT && URL=\$(echo $b64_url | base64 -d)"
  local extra=" --url=\"\$URL\""
  if [[ -n "$name" ]]; then
    b64_name=$(printf '%s' "$name" | base64 -w0)
    wrap+=" && NAME=\$(echo $b64_name | base64 -d)"
    extra+=" --name=\"\$NAME\""
  fi
  wrap+=" && php artisan seo:competitors add $parent$extra"
  in_lxc "$wrap"
}
cmd_competitors_remove()  { require_up; artisan "seo:competitors remove ${1:?사용법: competitors remove <competitor_id>}"; }
cmd_competitors_compare() { require_up; artisan "seo:competitors compare ${1:?사용법: competitors compare <parent_site_id>}"; }
cmd_competitors_analyze() {
  require_up
  local parent="${1:?사용법: competitors analyze <parent_site_id> [--max-pages N] [--depth 0|1]}"; shift || true
  local max="5" depth="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-pages|--max-pages=*) [[ "$1" == *=* ]] && max="${1#*=}"   || { max="$2";   shift; }; shift ;;
      --depth|--depth=*)         [[ "$1" == *=* ]] && depth="${1#*=}" || { depth="$2"; shift; }; shift ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  artisan "seo:competitors-analyze $parent --max-pages=$max --depth=$depth"
}

# ── Backlinks (Referer log + CSV import) ───────────────────────────────────
cmd_backlinks_set_log_source() {
  require_up
  local site_id="${1:-}"; shift || true
  [[ -n "$site_id" ]] || die "사용법: backlinks set-log-source <site_id> --vmid N [--path /var/log/nginx/access.log]"
  local vmid="" path="/var/log/nginx/access.log"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --vmid)    vmid="$2"; shift 2 ;;
      --vmid=*)  vmid="${1#*=}"; shift ;;
      --path)    path="$2"; shift 2 ;;
      --path=*)  path="${1#*=}"; shift ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  [[ -n "$vmid" ]] || die "--vmid 필요"
  local e_path; e_path="$(sql_escape "$path")"
  in_lxc "mariadb $DB_NAME -e \"UPDATE sites SET log_lxc_vmid=$vmid, log_path='$e_path' WHERE id=$site_id;\""
  ok "site #$site_id log source: LXC $vmid : $path"
}

cmd_backlinks_discover() {
  require_up
  local site_id="${1:-}"; shift || true
  [[ -n "$site_id" ]] || die "사용법: backlinks discover <site_id> [--tail N] [--include-rotated]"
  local tail_n="100000" rotated=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)     tail_n="$2"; shift 2 ;;
      --tail=*)   tail_n="${1#*=}"; shift ;;
      --include-rotated) rotated="1"; shift ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done

  # site 의 log_lxc_vmid / log_path 조회
  local row
  row=$(in_lxc "mariadb -B --skip-column-names $DB_NAME -e \"SELECT log_lxc_vmid, log_path, url FROM sites WHERE id=$site_id;\"" | tr '\t' '|')
  [[ -n "$row" ]] || die "site #$site_id 없음"
  local vmid path url
  vmid=$(echo "$row" | cut -d'|' -f1)
  path=$(echo "$row" | cut -d'|' -f2)
  url=$(echo "$row" | cut -d'|' -f3)
  [[ "$vmid" != "NULL" && -n "$vmid" ]] || die "site #$site_id 의 log_lxc_vmid 미설정. backlinks set-log-source 먼저"
  [[ "$path" != "NULL" && -n "$path" ]] || path="/var/log/nginx/access.log"

  log "source LXC $vmid : $path (tail=$tail_n, site=$url)"

  # LXC 에서 로그 수집 (rotated 포함 옵션)
  local hostfile="/tmp/bl-$site_id-$$.log"
  if [[ -n "$rotated" ]]; then
    pct exec "$vmid" -- bash -c "
      out=/tmp/bl-concat-$$.log
      for f in ${path}* $(dirname $path)/*.log.*.gz; do [ -e \"\$f\" ] || continue
        case \"\$f\" in *.gz) zcat \"\$f\" >> \"\$out\" ;; *) cat \"\$f\" >> \"\$out\" ;; esac
      done
      tail -n $tail_n \"\$out\"; rm -f \"\$out\"
    " > "$hostfile"
  else
    pct exec "$vmid" -- bash -c "tail -n $tail_n $path 2>/dev/null" > "$hostfile"
  fi

  local sz; sz=$(stat -c%s "$hostfile" 2>/dev/null || echo 0)
  [[ "$sz" -gt 0 ]] || { rm -f "$hostfile"; die "로그 비어있음 — path 확인"; }
  log "수집: $(du -sh "$hostfile" | cut -f1)"

  # 50183 으로 push 후 artisan 실행
  local lxc_file="/tmp/bl-$site_id.log"
  pct push "$VMID" "$hostfile" "$lxc_file"
  artisan "seo:backlinks-discover $site_id --log-file=$lxc_file"
  in_lxc "rm -f $lxc_file"
  rm -f "$hostfile"
}

cmd_backlinks_import() {
  require_up
  local site_id="${1:-}"; shift || true
  [[ -n "$site_id" ]] || die "사용법: backlinks import <site_id> --csv <file> [--source gsc|ahrefs|bing|manual]"
  local csv="" source=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --csv)     csv="$2"; shift 2 ;;
      --csv=*)   csv="${1#*=}"; shift ;;
      --source)  source="$2"; shift 2 ;;
      --source=*) source="${1#*=}"; shift ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  [[ -n "$csv" && -r "$csv" ]] || die "--csv <읽을 수 있는 파일> 필요"

  local lxc_csv="/tmp/bl-import-$site_id.csv"
  pct push "$VMID" "$csv" "$lxc_csv"
  local args="$site_id --csv=$lxc_csv"
  [[ -n "$source" ]] && args="$args --source=$source"
  artisan "seo:backlinks-import $args"
  in_lxc "rm -f $lxc_csv"
}

cmd_backlinks_stats() {
  require_up
  artisan "seo:backlinks-stats ${1:-}"
}

cmd_backlinks_audit() {
  require_up
  local site_id="" limit="" conc="6" timeout="12" days="14" force=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit|--limit=*)        [[ "$1" == *=* ]] && limit="${1#*=}"   || { limit="$2";   shift; }; shift ;;
      --concurrency|--concurrency=*) [[ "$1" == *=* ]] && conc="${1#*=}" || { conc="$2"; shift; }; shift ;;
      --timeout|--timeout=*)    [[ "$1" == *=* ]] && timeout="${1#*=}" || { timeout="$2"; shift; }; shift ;;
      --recheck-days|--recheck-days=*) [[ "$1" == *=* ]] && days="${1#*=}" || { days="$2"; shift; }; shift ;;
      --force)  force="--force"; shift ;;
      *)        site_id="$1"; shift ;;
    esac
  done
  local args="$site_id --concurrency=$conc --timeout=$timeout --recheck-days=$days"
  [[ -n "$limit" ]] && args="$args --limit=$limit"
  [[ -n "$force" ]] && args="$args $force"
  artisan "seo:backlinks-audit $args"
}

cmd_backlinks_bing() {
  require_up
  local site_id="" count="100" max="1000"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --count|--count=*) [[ "$1" == *=* ]] && count="${1#*=}" || { count="$2"; shift; }; shift ;;
      --max|--max=*)     [[ "$1" == *=* ]] && max="${1#*=}"   || { max="$2";   shift; }; shift ;;
      *)                 site_id="$1"; shift ;;
    esac
  done
  artisan "seo:backlinks-bing $site_id --count=$count --max=$max"
}

cmd_backlinks_list() {
  require_up
  local site_id="${1:-}"; shift || true
  [[ -n "$site_id" ]] || die "사용법: backlinks list <site_id> [--domain X] [--method M] [--days N] [--follow dofollow|nofollow] [--limit N]"
  local args="$site_id"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain|--domain=*)   [[ "$1" == *=* ]] && args="$args --domain=${1#*=}" || { args="$args --domain=$2"; shift; }; shift ;;
      --method|--method=*)   [[ "$1" == *=* ]] && args="$args --method=${1#*=}" || { args="$args --method=$2"; shift; }; shift ;;
      --days|--days=*)       [[ "$1" == *=* ]] && args="$args --days=${1#*=}"   || { args="$args --days=$2";   shift; }; shift ;;
      --follow|--follow=*)   [[ "$1" == *=* ]] && args="$args --follow=${1#*=}" || { args="$args --follow=$2"; shift; }; shift ;;
      --limit|--limit=*)     [[ "$1" == *=* ]] && args="$args --limit=${1#*=}"  || { args="$args --limit=$2";  shift; }; shift ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  artisan "seo:backlinks-list $args"
}

