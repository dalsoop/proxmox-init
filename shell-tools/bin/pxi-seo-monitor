}

# ── 메일 (SMTP 설정 + 발송 테스트) ─────────────────────────────────────────
cmd_mail_set_from() {
  require_up
  local addr="${1:-}" name=""
  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done
  [[ -n "$addr" ]] || die "사용법: mail set-from <address> [--name NAME]"
  cmd_env_set "MAIL_FROM_ADDRESS=$addr"
  [[ -n "$name" ]] && cmd_env_set "MAIL_FROM_NAME=$name"
  ok "MAIL_FROM = $addr${name:+ ($name)}"
}

cmd_mail_test() {
  require_up
  local target="${1:-}"
  local to=""
  if [[ -z "$target" ]]; then
    to="$DEFAULT_EMAIL"
  elif [[ "$target" =~ ^[0-9]+$ ]]; then
    to="$(in_lxc "mariadb -N -s $DB_NAME -e \"SELECT email FROM sites WHERE id=$target;\"")"
    [[ -n "$to" ]] || die "site id=$target 없음"
  else
    to="$target"
  fi
  log "메일 발송 테스트 → $to"
  in_lxc "cd $APP_ROOT && php artisan tinker --execute=\"Mail::raw('Prelik SEO Monitor mail test — $(date -Iseconds)', fn(\\\$m) => \\\$m->to('$to')->subject('SEO Monitor mail test'));\""
  ok "발송 완료 (수신 확인 필요)"
}

cmd_mail_show() {
  require_up
  in_lxc "grep '^MAIL_' $APP_ROOT/.env"
}

# ── Playwright API (내장, LXC 내부 127.0.0.1) ──────────────────────────────
cmd_playwright_status() {
  require_up
  echo "== systemd =="
  in_lxc "systemctl --no-pager --lines=0 status playwright-api 2>&1 | head -10"
  echo "== health =="
  in_lxc "curl -sf http://127.0.0.1:$PLAYWRIGHT_PORT/health || echo 'health check FAILED'"
}

cmd_playwright_logs() {
  require_up
  in_lxc "journalctl -u playwright-api -n ${1:-200} --no-pager"
}

cmd_playwright_restart() {
  require_up
  in_lxc "systemctl restart playwright-api && sleep 2 && curl -sf http://127.0.0.1:$PLAYWRIGHT_PORT/health"
  ok "restart OK"
}

cmd_playwright_install() {
  require_up
  [ -d "$SHARE_DIR" ] || die "템플릿 폴더 없음: $SHARE_DIR"
  log "Playwright 올인원 설치: $PLAYWRIGHT_ROOT/{docker,tests} + NAS 바인드마운트"

  # 1. NAS 바인드 마운트 보장 (호스트 측)
  mkdir -p "$NAS_HOST_PATH"
  if ! pct config "$VMID" | grep -q "mp=/mnt/seo-artifacts"; then
    log "LXC $VMID mp1 바인드 추가: $NAS_HOST_PATH → $ARTIFACTS_ROOT"
    pct set "$VMID" --mp1 "$NAS_HOST_PATH,mp=$ARTIFACTS_ROOT,backup=0"
    pct reboot "$VMID"
    sleep 15
  fi

  # 2. docker/ tests/ 씨드 푸시
  in_lxc "mkdir -p $PLAYWRIGHT_DOCKER_DIR $PLAYWRIGHT_TESTS_DIR/specs"
  for f in Dockerfile package.json playwright.config.ts server.js; do
    pct push "$VMID" "$SHARE_DIR/docker/$f" "$PLAYWRIGHT_DOCKER_DIR/$f"
  done
  for f in package.json playwright.config.ts; do
    pct push "$VMID" "$SHARE_DIR/tests/$f" "$PLAYWRIGHT_TESTS_DIR/$f"
  done
  pct push "$VMID" "$SHARE_DIR/tests/specs/seo-audit.spec.ts" "$PLAYWRIGHT_TESTS_DIR/specs/seo-audit.spec.ts"

  # 3. npm install + 브라우저 다운로드
  log "docker/ 의존성 + Chromium"
  in_lxc "cd $PLAYWRIGHT_DOCKER_DIR && npm install --omit=dev --no-audit --no-fund"
  in_lxc "cd $PLAYWRIGHT_DOCKER_DIR && npx --yes playwright install chromium"
  log "tests/ 의존성 + Chromium (@playwright/test)"
  in_lxc "cd $PLAYWRIGHT_TESTS_DIR && npm install --no-audit --no-fund"
  in_lxc "cd $PLAYWRIGHT_TESTS_DIR && npx playwright install chromium"

  # 4. systemd
  pct push "$VMID" "$SHARE_DIR/playwright-api.service" /etc/systemd/system/playwright-api.service
  in_lxc "systemctl daemon-reload && systemctl enable playwright-api && systemctl restart playwright-api && sleep 2"
  in_lxc "curl -sf http://127.0.0.1:$PLAYWRIGHT_PORT/health" \
    && ok "Playwright API 기동 OK" || die "기동 실패"

  # 5. 앱 .env 포인트
  in_lxc "
    cd $APP_ROOT
    grep -q '^PLAYWRIGHT_API_URL=' .env \
      && sed -i 's|^PLAYWRIGHT_API_URL=.*|PLAYWRIGHT_API_URL=http://127.0.0.1:$PLAYWRIGHT_PORT|' .env \
      || echo 'PLAYWRIGHT_API_URL=http://127.0.0.1:$PLAYWRIGHT_PORT' >> .env
    grep -q '^PLAYWRIGHT_FALLBACK_URL=' .env \
      && sed -i 's|^PLAYWRIGHT_FALLBACK_URL=.*|PLAYWRIGHT_FALLBACK_URL=http://127.0.0.1:$PLAYWRIGHT_PORT|' .env \
      || echo 'PLAYWRIGHT_FALLBACK_URL=http://127.0.0.1:$PLAYWRIGHT_PORT' >> .env
    php artisan config:clear >/dev/null
    php artisan config:cache >/dev/null
  "
  ok "올인원 설치 완료 — artifacts → $ARTIFACTS_ROOT/{domain}/"
}

# ── tests (on-demand @playwright/test 실행) ────────────────────────────────
cmd_tests_run() {
  require_up
  local target_url="" domain=""
  # 인자: site_id 또는 --url URL
  if [[ $# -gt 0 && "$1" =~ ^[0-9]+$ ]]; then
    target_url="$(in_lxc "mariadb -N -s $DB_NAME -e \"SELECT url FROM sites WHERE id=$1;\"")"
    [[ -n "$target_url" ]] || die "site id=$1 없음"
  else
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --url)    target_url="$2"; shift 2 ;;
        --domain) domain="$2"; shift 2 ;;
        *) die "사용법: tests run <site_id> 또는 tests run --url URL [--domain D]" ;;
      esac
    done
  fi
  [[ -n "$target_url" ]] || die "타겟 URL 필수"
  [[ -z "$domain" ]] && domain="$(echo "$target_url" | sed -E 's|^https?://||; s|/.*||')"
  log "tests run → $target_url  (domain=$domain)"
  in_lxc "cd $PLAYWRIGHT_TESTS_DIR && \
    PLAYWRIGHT_DOMAIN='$domain' \
    PLAYWRIGHT_TARGET_URL='$target_url' \
    ARTIFACTS_ROOT='$ARTIFACTS_ROOT' \
    npx playwright test ${2:-}"
  ok "artifacts → $ARTIFACTS_ROOT/$domain/"
}

cmd_tests_results() {
  require_up
  local domain="${1:-}"
  if [[ -z "$domain" ]]; then
    in_lxc "ls -la $ARTIFACTS_ROOT/ 2>/dev/null"
  else
    in_lxc "find $ARTIFACTS_ROOT/$domain -maxdepth 3 -type d 2>/dev/null | head -30"
    in_lxc "ls -la $ARTIFACTS_ROOT/$domain/last-report.json 2>/dev/null"
  fi
}

cmd_tests_report() {
  require_up
  local domain="${1:-}"; [[ -n "$domain" ]] || die "사용법: tests report <domain>"
  in_lxc "cd $PLAYWRIGHT_TESTS_DIR && npx playwright show-report $ARTIFACTS_ROOT/$domain/html-report"
}


cmd_status() {
  require_up
  echo "== LXC =="
  pxi-laravel status "$VMID" 2>/dev/null | head -12
  echo; echo "== Playwright API =="
  in_lxc "systemctl is-active playwright-api; curl -sf http://127.0.0.1:$PLAYWRIGHT_PORT/health || echo 'unhealthy'"
  echo; echo "== Sites =="
  in_lxc "mariadb $DB_NAME -e 'SELECT COUNT(*) AS total, SUM(is_active) AS active FROM sites; SELECT COUNT(*) AS analyses FROM analyses;'"
  echo "== Latest =="
  in_lxc "mariadb $DB_NAME -e 'SELECT id, url, latest_score, last_analyzed_at FROM sites ORDER BY last_analyzed_at DESC LIMIT 10;'"
}

cmd_url() { echo "https://prelik-seo-monitor.50.internal.kr"; }

# ── bootstrap (playwright install + schedule install + sites import-wp) ────
cmd_bootstrap() {
  require_up
  log "1/3 Playwright 올인원 설치"
  cmd_playwright_install
  log "2/3 Schedule systemd 등록"
  cmd_schedule_install
  log "3/3 WP 사이트 자동 임포트"
  cmd_sites_import_wp
  ok "bootstrap 완료 — https://prelik-seo-monitor.50.internal.kr"
}

# ── pxi-laravel 패스스루 ────────────────────────────────────────────────────
cmd_logs()    { pxi-laravel logs    "$VMID" "${1:-app}"; }
cmd_artisan() { pxi-laravel artisan "$VMID" "$@"; }
cmd_update()  { pxi-laravel update  "$VMID"; }
cmd_doctor()  { pxi-laravel doctor  "$VMID"; }
cmd_env()     { pxi-laravel env-show "$VMID"; }
cmd_shell()   { pct enter "$VMID"; }

usage() {
  cat <<EOF
pxi-seo-monitor — Prelik SEO Monitor (LXC $VMID, https://prelik-seo-monitor.50.internal.kr)

Usage:
  pxi-seo-monitor bootstrap                        # 올인원 (playwright install + schedule + import-wp)
  pxi-seo-monitor test [filter]                    # php artisan test (--filter 인자 전달)

  pxi-seo-monitor sites list
  pxi-seo-monitor sites add --url URL [--name N] [--email E] [--schedule HH:MM]
  pxi-seo-monitor sites delete <id>
  pxi-seo-monitor sites activate / deactivate / set-email <id> [<email>]
  pxi-seo-monitor sites auth show <id>
  pxi-seo-monitor sites auth set <id> <http_basic|wp_post_password|form> <creds>
  pxi-seo-monitor sites auth clear <id>
  pxi-seo-monitor sites discover-wp                # 전체 LXC 에서 WP 자동 탐지
  pxi-seo-monitor sites import-wp [--dry-run] [--email E]
  pxi-seo-monitor crawl [site_id] [--depth N] [--max N] [--timeout S]  # Guzzle BFS
  pxi-seo-monitor pages list [site_id]             # 크롤된 페이지 목록
  pxi-seo-monitor pages clear <site_id>
  pxi-seo-monitor hints list [site_id] [--severity critical|warning|info] [--analyzer meta|...] [--top N]
  pxi-seo-monitor hints materialize [site_id]      # 기존 analyses 에서 hints 재추출
  pxi-seo-monitor hints clear <site_id>
  pxi-seo-monitor analyze       [site_id]               # seo:analyze 홈 (전체 | 특정)
  pxi-seo-monitor analyze-pages [site_id] [--limit N] [--include-homepage]  # 페이지 단위 분석 (page_id 연결 hints)
  pxi-seo-monitor report        [site_id]               # seo:report

  pxi-seo-monitor playwright status
  pxi-seo-monitor playwright logs [lines]
  pxi-seo-monitor playwright restart
  pxi-seo-monitor playwright install               # 올인원 재설치 (docker/+tests/, NAS 바인드, systemd, 브라우저)

  pxi-seo-monitor tests run <site_id | --url URL [--domain D]>   # @playwright/test 실행, 도메인별 NAS 저장
  pxi-seo-monitor tests results [domain]            # NAS 아티팩트 목록
  pxi-seo-monitor tests report <domain>             # html-report 서빙

  pxi-seo-monitor competitors list [parent_site_id]
  pxi-seo-monitor competitors add <parent_site_id> --url <url> [--name <name>]
  pxi-seo-monitor competitors remove <competitor_id>
  pxi-seo-monitor competitors analyze <parent_site_id> [--max-pages 5] [--depth 0|1]
  pxi-seo-monitor competitors compare <parent_site_id>                 # 지표 사이드바이사이드 표

  pxi-seo-monitor backlinks set-log-source <site_id> --vmid N [--path /var/log/nginx/access.log]
  pxi-seo-monitor backlinks discover <site_id> [--tail N] [--include-rotated]  # nginx log → referer 집계
  pxi-seo-monitor backlinks import <site_id> --csv <파일> [--source gsc|ahrefs|bing|manual]
  pxi-seo-monitor backlinks audit [site_id] [--limit N] [--force]                    # source_url HEAD 생존 검증
  pxi-seo-monitor backlinks bing  [site_id] [--count 100] [--max 1000]                # Bing Webmaster API (env BING_WEBMASTER_API_KEY)
  pxi-seo-monitor backlinks stats [site_id]
  pxi-seo-monitor backlinks list <site_id> [--domain X] [--method M] [--days N] [--follow dofollow|nofollow] [--limit N]

  pxi-seo-monitor links audit [site_id] [--limit N] [--external-only] [--force]  # HEAD 배치 검증
  pxi-seo-monitor links stats [site_id]                                  # total/internal/broken/unchecked
  pxi-seo-monitor links broken <site_id> [--type internal|external]      # 깨진 링크 목록
  pxi-seo-monitor links orphans <site_id>                                # 내부 inbound=0 페이지
  pxi-seo-monitor links graph <site_id>                                  # PageRank top10 + orphan/dead-end

  pxi-seo-monitor geo-outcome providers                       # 제공자 API key 상태 확인
  pxi-seo-monitor geo-outcome queries list [site_id]
  pxi-seo-monitor geo-outcome queries add <site_id> "<텍스트>"
  pxi-seo-monitor geo-outcome queries remove <query_id>
  pxi-seo-monitor geo-outcome queries toggle <query_id>       # active on/off
  pxi-seo-monitor geo-outcome queries seed <site_id> [--limit N]   # 분석 기반 자동 제안
  pxi-seo-monitor geo-outcome queries clear <site_id>
  pxi-seo-monitor geo-outcome run [site_id] [--provider=openai|perplexity|all] [--query=ID | --text="..."]
  pxi-seo-monitor geo-outcome pending [site_id] [--provider claude] [--since 7] [--json] [--remind]
  pxi-seo-monitor geo-outcome submit --query-id=N --response="..." [--citations="url1 url2"]
  pxi-seo-monitor geo-outcome submit --site-id=N --text="..." --response-stdin < answer.txt
  pxi-seo-monitor geo-outcome stats [site_id] [--days 30] [--list --limit 50]

  pxi-seo-monitor schedule install                  # Laravel schedule:work systemd 등록
  pxi-seo-monitor schedule list                     # routes/console.php 의 스케줄 목록
  pxi-seo-monitor schedule status / logs [N] / restart

  pxi-seo-monitor env show / edit / set KEY=VAL / unset KEY    # .env 프로그래밍 편집 + 캐시 자동 재생성
  pxi-seo-monitor cache refresh / clear
  pxi-seo-monitor mail show / set-from <addr> [--name N] / test [site_id|email]

  pxi-seo-monitor status / url
  pxi-seo-monitor logs [app|nginx|php|error]
  pxi-seo-monitor artisan <args...>
  pxi-seo-monitor update / doctor / shell

환경변수:
  SEO_VMID (기본 $VMID)
  SEO_DEFAULT_EMAIL (기본 $DEFAULT_EMAIL)
  SEO_PLAYWRIGHT_PORT (기본 $PLAYWRIGHT_PORT, 127.0.0.1 only)
EOF
}

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    sites)
      local sub="${1:-list}"; shift || true
      case "$sub" in
        list)         cmd_sites_list ;;
        add)          cmd_sites_add "$@" ;;
        delete|rm)    cmd_sites_delete "$@" ;;
        activate)     cmd_sites_activate "$@" ;;
        deactivate)   cmd_sites_deactivate "$@" ;;
        set-email)    cmd_sites_set_email "$@" ;;
        auth)         cmd_sites_auth "$@" ;;
        discover-wp)  cmd_sites_discover_wp ;;
        import-wp)    cmd_sites_import_wp "$@" ;;
        *) usage; die "알 수 없는 sites 서브커맨드: $sub" ;;
      esac
      ;;
    playwright|pw)
      local sub="${1:-status}"; shift || true
      case "$sub" in
        status)   cmd_playwright_status ;;
        logs)     cmd_playwright_logs "$@" ;;
        restart)  cmd_playwright_restart ;;
        install)  cmd_playwright_install ;;
        *) usage; die "알 수 없는 playwright 서브커맨드: $sub" ;;
      esac
      ;;
    tests)
      local sub="${1:-results}"; shift || true
      case "$sub" in
        run)      cmd_tests_run "$@" ;;
        results)  cmd_tests_results "$@" ;;
        report)   cmd_tests_report "$@" ;;
        *) usage; die "알 수 없는 tests 서브커맨드: $sub" ;;
      esac
      ;;
    schedule)
      local sub="${1:-status}"; shift || true
      case "$sub" in
        install)  cmd_schedule_install ;;
        status)   cmd_schedule_status ;;
        logs)     cmd_schedule_logs "$@" ;;
        restart)  cmd_schedule_restart ;;
        list)     cmd_schedule_list ;;
        *) usage; die "알 수 없는 schedule 서브커맨드: $sub" ;;
      esac
      ;;
    env)
      local sub="${1:-show}"; shift || true
      case "$sub" in
        show)     cmd_env ;;
        edit)     pxi-laravel env-edit "$VMID" ;;
        set)      cmd_env_set "$@" ;;
        unset)    cmd_env_unset "$@" ;;
        *) usage; die "알 수 없는 env 서브커맨드: $sub" ;;
      esac
      ;;
    cache)
      local sub="${1:-refresh}"; shift || true
      case "$sub" in
        refresh|rebuild)  cmd_cache_refresh ;;
        clear)            cmd_cache_clear ;;
        *) usage; die "알 수 없는 cache 서브커맨드: $sub" ;;
      esac
      ;;
    mail)
      local sub="${1:-show}"; shift || true
      case "$sub" in
        show)         cmd_mail_show ;;
        set-from)     cmd_mail_set_from "$@" ;;
        test)         cmd_mail_test "$@" ;;
        *) usage; die "알 수 없는 mail 서브커맨드: $sub" ;;
      esac
      ;;
    bootstrap) cmd_bootstrap ;;
    test)      cmd_test "$@" ;;
    analyze)       cmd_analyze "$@" ;;
    analyze-pages) cmd_analyze_pages "$@" ;;
    report)        cmd_report "$@" ;;
    crawl)    cmd_crawl "$@" ;;
    pages)
      local sub="${1:-list}"; shift || true
      case "$sub" in
        list)   cmd_pages_list "$@" ;;
        clear)  cmd_pages_clear "$@" ;;
        *) usage; die "알 수 없는 pages 서브커맨드: $sub" ;;
      esac
      ;;
    hints)
      local sub="${1:-list}"; shift || true
      case "$sub" in
        list)         cmd_hints_list "$@" ;;
        materialize)  cmd_hints_materialize "$@" ;;
        clear)        cmd_hints_clear "$@" ;;
        *) usage; die "알 수 없는 hints 서브커맨드: $sub" ;;
      esac
      ;;
    competitors|comp)
      local sub="${1:-list}"; shift || true
      case "$sub" in
        list)       cmd_competitors_list "$@" ;;
        add)        cmd_competitors_add "$@" ;;
        remove|rm)  cmd_competitors_remove "$@" ;;
        analyze)    cmd_competitors_analyze "$@" ;;
        compare)    cmd_competitors_compare "$@" ;;
        *) usage; die "알 수 없는 competitors 서브커맨드: $sub" ;;
      esac
      ;;
    backlinks|bl)
      local sub="${1:-stats}"; shift || true
      case "$sub" in
        set-log-source) cmd_backlinks_set_log_source "$@" ;;
        discover)       cmd_backlinks_discover "$@" ;;
        import)         cmd_backlinks_import "$@" ;;
        audit)          cmd_backlinks_audit "$@" ;;
        bing)           cmd_backlinks_bing "$@" ;;
        stats)          cmd_backlinks_stats "$@" ;;
        list)           cmd_backlinks_list "$@" ;;
        *) usage; die "알 수 없는 backlinks 서브커맨드: $sub" ;;
      esac
      ;;
    links)
      local sub="${1:-stats}"; shift || true
      case "$sub" in
        audit)    cmd_links_audit "$@" ;;
        stats)    cmd_links_stats "$@" ;;
        broken)   cmd_links_broken "$@" ;;
        orphans)  cmd_links_orphans "$@" ;;
        graph)    cmd_links_graph "$@" ;;
        *) usage; die "알 수 없는 links 서브커맨드: $sub" ;;
      esac
      ;;
    geo-outcome|geo)
      local sub="${1:-stats}"; shift || true
      case "$sub" in
        run)        cmd_geo_run "$@" ;;
        stats)      cmd_geo_stats "$@" ;;
        providers)  cmd_geo_providers ;;
        pending)    cmd_geo_pending "$@" ;;
        submit)     cmd_geo_submit "$@" ;;
        queries)
          local sub2="${1:-list}"; shift || true
          case "$sub2" in
            list)    cmd_geo_queries_list "$@" ;;
            add)     cmd_geo_queries_add "$@" ;;
            remove|rm) cmd_geo_queries_remove "$@" ;;
            toggle)  cmd_geo_queries_toggle "$@" ;;
            seed)    cmd_geo_queries_seed "$@" ;;
            clear)   cmd_geo_queries_clear "$@" ;;
            *) usage; die "알 수 없는 geo-outcome queries 서브커맨드: $sub2" ;;
          esac
          ;;
        *) usage; die "알 수 없는 geo-outcome 서브커맨드: $sub" ;;
      esac
      ;;
    status)   cmd_status ;;
    url)      cmd_url ;;
    logs)     cmd_logs "$@" ;;
    artisan)  cmd_artisan "$@" ;;
    update)   cmd_update ;;
    doctor)   cmd_doctor ;;
    shell)    cmd_shell ;;
    help|--help|-h) usage ;;
    *) usage; die "알 수 없는 커맨드: $cmd" ;;
  esac
}

main "$@"
