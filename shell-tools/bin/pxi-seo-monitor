cmd_geo_run() {
  require_up
  local site_id="" provider="all" query="" text=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider)   provider="$2"; shift 2 ;;
      --provider=*) provider="${1#*=}"; shift ;;
      --query)      query="$2"; shift 2 ;;
      --query=*)    query="${1#*=}"; shift ;;
      --text)       text="$2"; shift 2 ;;
      --text=*)     text="${1#*=}"; shift ;;
      --*)          die "알 수 없는 옵션: $1" ;;
      *)            site_id="$1"; shift ;;
    esac
  done
  local args=""
  [[ -n "$site_id" ]] && args="$args $site_id"
  args="$args --provider=$provider"
  [[ -n "$query"   ]] && args="$args --query=$query"
  [[ -n "$text"    ]] && args="$args --text=\"$text\""
  artisan "seo:geo-outcome $args"
}

cmd_geo_stats() {
