      --days=*)  days="${1#*=}"; shift ;;
      --list)    list="--list"; shift ;;
      --limit)   limit="$2"; shift 2 ;;
      --limit=*) limit="${1#*=}"; shift ;;
      *)         site_id="$1"; shift ;;
    esac
  done
  local args="$site_id --days=$days"
  [[ -n "$list" ]] && args="$args --list --limit=$limit"
  artisan "seo:geo-outcome-stats $args"
}

