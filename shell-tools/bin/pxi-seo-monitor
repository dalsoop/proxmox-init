# ── .env 관리 (프로그래밍 편집, sed 수동 조작 대체) ──────────────────────────
cmd_env_set() {
  require_up
  local kv="${1:-}"; [[ "$kv" == *"="* ]] || die "사용법: env set KEY=VAL"
  local key="${kv%%=*}" val="${kv#*=}"
  [[ -n "$key" ]] || die "KEY 비어있음"
  # sed escape 해서 .env 내 KEY= 라인 치환 (없으면 추가), 값은 "..." 로 감쌈
  local e_val; e_val="$(printf '%s' "$val" | sed 's|[&/\\]|\\&|g')"
  in_lxc "
    cd $APP_ROOT
    if grep -q '^${key}=' .env; then
      sed -i -E 's|^${key}=.*|${key}=\"${e_val}\"|' .env
    else
      printf '%s=\"%s\"\n' '${key}' '${val}' >> .env
    fi
    php artisan config:clear >/dev/null
    php artisan config:cache >/dev/null
  "
  ok ".env: $key=***"
}

cmd_env_unset() {
  require_up
  local key="${1:-}"; [[ -n "$key" ]] || die "사용법: env unset KEY"
  in_lxc "
    cd $APP_ROOT
    sed -i -E '/^${key}=/d' .env
    php artisan config:clear >/dev/null
    php artisan config:cache >/dev/null
  "
  ok ".env: $key 제거"
}

