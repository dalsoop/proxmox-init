#!/usr/bin/env bash
# pxi-laravel — 자체 호스팅 Laravel LXC 관리 CLI
# 패턴: pxi-wordpress 미러. nginx + php-fpm + mariadb + composer + node + Traefik.
#
# Usage:
#   pxi-laravel install --vmid N --hostname HN --domain D (--repo URL | --source-dir PATH) [opts]
#   pxi-laravel setup    <vmid>           # composer/npm/migrate/cache 재실행
#   pxi-laravel update   <vmid>           # git pull + setup + opcache 재시작
#   pxi-laravel artisan  <vmid> <args...>
#   pxi-laravel logs     <vmid> [app|nginx|php|error]
#   pxi-laravel status   <vmid>
#   pxi-laravel doctor   <vmid>
#   pxi-laravel env-show <vmid> [--decrypt]
#   pxi-laravel env-edit <vmid>
#   pxi-laravel env-init <vmid>           # dotenvx 초기화 (.env 암호화 + systemd override)
#   pxi-laravel db       <vmid> [client|dump|psql…]
#   pxi-laravel delete   <vmid>
#   pxi-laravel list
#   pxi-laravel help

set -euo pipefail

TEMPLATE="local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
STORAGE="local-lvm"
BRIDGE="vmbr1"
GW="10.0.50.1"
NETMASK="/16"
APP_ROOT="/var/www/html"
TAG="laravel"

c_red()   { printf '\033[0;31m%s\033[0m' "$*"; }
c_green() { printf '\033[0;32m%s\033[0m' "$*"; }
c_blue()  { printf '\033[0;34m%s\033[0m' "$*"; }
c_yel()   { printf '\033[0;33m%s\033[0m' "$*"; }
log()  { echo "$(c_blue '[pxi-laravel]') $*" >&2; }
ok()   { echo "$(c_green '✓') $*" >&2; }
warn() { echo "$(c_yel '⚠') $*" >&2; }
die()  { echo "$(c_red '✗') $*" >&2; exit 1; }

in_lxc() { pct exec "$1" -- bash -lc "$2"; }

# ── LXC 상태/존재 헬퍼 ──────────────────────────────────────────────────────
lxc_exists() { pct config "$1" >/dev/null 2>&1; }
lxc_running() { [ "$(pct status "$1" 2>/dev/null | awk '{print $2}')" = "running" ]; }
lxc_ip() { pct config "$1" 2>/dev/null | grep -oP 'ip=\K[0-9.]+' | head -1; }

require_laravel() {
  local vmid="$1"
  lxc_exists "$vmid" || die "LXC $vmid 없음"
  pct config "$vmid" | grep -qE "^tags:.*\b$TAG\b" \
    || die "LXC $vmid 는 laravel 태그가 없음 (pxi-laravel install 로 생성된 게 아님)"
}

gen_pw() { head -c 24 /dev/urandom | base64 | tr -d '/+=' | head -c 24; }

# ── 설치 ────────────────────────────────────────────────────────────────────
usage_install() {
  cat <<'EOF'
LXC 생성 + nginx + PHP-FPM + MariaDB + Composer + Node + Laravel 앱 배포 + Traefik 라우트

Usage:
  pxi-laravel install \
    --vmid <VMID> --hostname <HN> --domain <DOMAIN> (--repo <URL> | --source-dir <PATH>) \
    [--ip 10.0.50.XX] [--branch main] [--app-name "name"] \
    [--disk 16] [--cores 2] [--memory 2048] \
    [--db-name laravel] [--db-user laravel] [--db-password PW] \
    [--php 8.2|8.3|8.4] [--node 20|22] \
    [--no-npm] [--no-migrate] [--no-traefik] \
    [--composer-remove "pkg/a,pkg/b"] [--composer-remove-repos "host1,host2"]

예:
  pxi-laravel install \
    --vmid 50183 --hostname ranode-seo --domain ranode-seo.50.internal.kr \
    --repo http://gitlab.internal.kr/dalsoop/legacy/ranode-seo.git \
    --db-name ranode_seo --db-user ranode_seo

  pxi-laravel install \
    --vmid 50187 --hostname keyword-insight --domain keyword-insight.50.internal.kr \
    --source-dir /root/workspace/keyword-insight
EOF
}

cmd_install() {
  local vmid="" hostname="" domain="" repo="" source_dir="" branch="main"
  local ip="" app_name=""
  local disk="16" cores="2" memory="2048"
  local db_name="" db_user="" db_password=""
  local php_ver="8.2" node_ver="20"
  local do_npm="yes" do_migrate="yes" do_traefik="yes"
  local composer_remove=""
  local composer_remove_repos=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --vmid)        vmid="$2"; shift 2 ;;
      --hostname)    hostname="$2"; shift 2 ;;
      --domain)      domain="$2"; shift 2 ;;
      --repo)        repo="$2"; shift 2 ;;
      --source-dir)  source_dir="$2"; shift 2 ;;
      --branch)      branch="$2"; shift 2 ;;
      --ip)          ip="$2"; shift 2 ;;
      --app-name)    app_name="$2"; shift 2 ;;
      --disk)        disk="$2"; shift 2 ;;
      --cores)       cores="$2"; shift 2 ;;
      --memory)      memory="$2"; shift 2 ;;
      --db-name)     db_name="$2"; shift 2 ;;
      --db-user)     db_user="$2"; shift 2 ;;
      --db-password) db_password="$2"; shift 2 ;;
      --php)         php_ver="$2"; shift 2 ;;
      --node)        node_ver="$2"; shift 2 ;;
      --no-npm)      do_npm="no"; shift ;;
      --no-migrate)  do_migrate="no"; shift ;;
      --no-traefik)  do_traefik="no"; shift ;;
      --composer-remove)       composer_remove="$2"; shift 2 ;;
      --composer-remove-repos) composer_remove_repos="$2"; shift 2 ;;
      -h|--help)     usage_install; exit 0 ;;
      *) die "알 수 없는 옵션: $1" ;;
    esac
  done

  [[ -n "$vmid" && -n "$hostname" && -n "$domain" ]] \
    || { usage_install; die "--vmid/--hostname/--domain 는 필수"; }
  if [[ -n "$repo" && -n "$source_dir" ]]; then
    usage_install
    die "--repo 와 --source-dir 는 동시에 사용할 수 없음"
  fi
  if [[ -z "$repo" && -z "$source_dir" ]]; then
    usage_install
    die "--repo 또는 --source-dir 중 하나는 필수"
  fi
  if [[ -n "$source_dir" ]]; then
    [[ -d "$source_dir" ]] || die "source-dir 없음: $source_dir"
    [[ -f "$source_dir/composer.json" ]] || die "Laravel 앱이 아님: $source_dir/composer.json 없음"
  fi

  [[ -z "$app_name"    ]] && app_name="$hostname"
  [[ -z "$db_name"     ]] && db_name="$(echo "$hostname" | tr '-' '_')"
  [[ -z "$db_user"     ]] && db_user="$db_name"
  [[ -z "$db_password" ]] && db_password="$(gen_pw)"

  # IP 자동 할당
  if [[ -z "$ip" ]]; then
    for i in $(seq 180 250); do
      ping -c1 -W1 "10.0.50.$i" >/dev/null 2>&1 || { ip="10.0.50.$i"; break; }
    done
  fi
  [[ -n "$ip" ]] || die "IP 자동 할당 실패 — --ip 로 지정하세요"

  local source_label
  if [[ -n "$source_dir" ]]; then
    source_label="source-dir: $source_dir"
  else
    source_label="repo: $repo (branch=$branch)"
  fi

  log "설치 요약:"
  cat <<EOF >&2
  VMID:       $vmid
  Hostname:   $hostname
  Domain:     $domain
  IP:         $ip$NETMASK (gw $GW, $BRIDGE)
  Source:     $source_label
  Resources:  ${cores}c / ${memory}MB / ${disk}GB
  PHP:        $php_ver        Node: $node_ver
  DB:         $db_name / user=$db_user
  Migrate:    $do_migrate   NPM build: $do_npm   Traefik: $do_traefik
EOF

  if lxc_exists "$vmid"; then
    die "LXC $vmid 이미 존재. 다른 vmid 쓰거나 pxi-laravel delete $vmid"
  fi

  # ── 1. LXC 생성 ─────────────────────────────────────────────────────────
  log "[1/9] LXC 생성"
  local pw; pw="$(gen_pw)"
  pct create "$vmid" "$TEMPLATE" \
    --hostname "$hostname" \
    --cores "$cores" \
    --memory "$memory" \
    --rootfs "${STORAGE}:${disk}" \
    --net0 "name=eth0,bridge=${BRIDGE},gw=${GW},ip=${ip}${NETMASK},type=veth" \
    --onboot 1 \
    --unprivileged 1 \
    --features nesting=1 \
    --password "$pw" \
    --tags "$TAG" \
    >/dev/null
  pct start "$vmid"
  sleep 3
  in_lxc "$vmid" "until getent hosts deb.debian.org >/dev/null 2>&1; do sleep 1; done" || true
  ok "LXC $vmid 부팅 완료"

  # ── 2. 시스템 패키지 ─────────────────────────────────────────────────────
  log "[2/9] 시스템 패키지 설치"
  in_lxc "$vmid" "
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y -qq --no-install-recommends ca-certificates curl gnupg git unzip nginx \
      mariadb-server mariadb-client supervisor cron
  " >&2
  ok "OS base 설치"

  # ── 3. PHP 설치 (Sury) ──────────────────────────────────────────────────
  log "[3/9] PHP ${php_ver} 설치"
  in_lxc "$vmid" "
    export DEBIAN_FRONTEND=noninteractive
    curl -fsSL https://packages.sury.org/php/apt.gpg | gpg --dearmor -o /usr/share/keyrings/sury-php.gpg
    echo 'deb [signed-by=/usr/share/keyrings/sury-php.gpg] https://packages.sury.org/php/ trixie main' \
      > /etc/apt/sources.list.d/sury-php.list
    apt-get update -qq
    apt-get install -y -qq --no-install-recommends \
      php${php_ver}-fpm php${php_ver}-cli php${php_ver}-common php${php_ver}-mysql \
      php${php_ver}-mbstring php${php_ver}-xml php${php_ver}-zip php${php_ver}-gd \
      php${php_ver}-curl php${php_ver}-bcmath php${php_ver}-intl php${php_ver}-redis \
      php${php_ver}-bz2 php${php_ver}-opcache php${php_ver}-sqlite3
    update-alternatives --set php /usr/bin/php${php_ver} || true
  " >&2
  ok "PHP ${php_ver}"

  # ── 4. Composer ─────────────────────────────────────────────────────────
  log "[4/9] Composer 설치"
  in_lxc "$vmid" "
    curl -fsSL https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer --quiet
    composer --version
  " >&2
  ok "Composer"

  # ── 5. Node.js ──────────────────────────────────────────────────────────
  log "[5/9] Node.js ${node_ver} 설치"
  in_lxc "$vmid" "
    export DEBIAN_FRONTEND=noninteractive
    curl -fsSL https://deb.nodesource.com/setup_${node_ver}.x | bash -
    apt-get install -y -qq --no-install-recommends nodejs
    node --version; npm --version
  " >&2
  ok "Node.js ${node_ver}"

  # ── 6. MariaDB + DB 생성 ────────────────────────────────────────────────
  log "[6/9] MariaDB 설정 + DB/유저 생성"
  in_lxc "$vmid" "
    systemctl enable --now mariadb
    mariadb -e \"CREATE DATABASE IF NOT EXISTS \\\`${db_name}\\\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;\"
    mariadb -e \"CREATE USER IF NOT EXISTS '${db_user}'@'localhost' IDENTIFIED BY '${db_password}';\"
    mariadb -e \"GRANT ALL ON \\\`${db_name}\\\`.* TO '${db_user}'@'localhost';\"
    mariadb -e 'FLUSH PRIVILEGES;'
  " >&2
  ok "MariaDB 준비"

  # ── 7. 앱 소스 배치 + .env ───────────────────────────────────────────────
  if [[ -n "$source_dir" ]]; then
    log "[7/9] 로컬 소스 배치 ($source_dir)"
    _deploy_source_dir "$vmid" "$source_dir"
  else
    log "[7/9] 리포 클론 ($repo @ $branch)"
    in_lxc "$vmid" "
      rm -rf $APP_ROOT
      git clone --branch '$branch' --depth 1 '$repo' $APP_ROOT
      cd $APP_ROOT
      [ -f .env ] || cp .env.example .env
    " >&2
  fi

  # composer.json 에서 패키지 제거 (dead private repo 대응)
  if [[ -n "$composer_remove" ]]; then
    log "composer.json 에서 패키지 제거: $composer_remove"
    # LXC 내부에 헬퍼 스크립트 드롭 후 실행 (shell quoting 지옥 회피)
    pct exec "$vmid" -- bash -c "cat > /tmp/_cr.py <<'PYEOF'
import json, os
pkgs = [p.strip() for p in os.environ['PKGS'].split(',') if p.strip()]
path = '$APP_ROOT/composer.json'
data = json.load(open(path))
for p in pkgs:
    data.get('require', {}).pop(p, None)
    data.get('require-dev', {}).pop(p, None)
json.dump(data, open(path,'w'), indent=4)
print('removed:', pkgs)
PYEOF"
    pct exec "$vmid" -- bash -c "PKGS='$composer_remove' python3 /tmp/_cr.py" >&2
    # composer.lock 는 제거된 패키지를 여전히 붙잡고 있으므로 삭제 → install 시 재해결
    in_lxc "$vmid" "rm -f $APP_ROOT/composer.lock" >&2
  fi

  # composer.json 의 repositories 섹션에서 죽은 호스트 제거
  if [[ -n "$composer_remove_repos" ]]; then
    log "composer.json repositories 에서 호스트 제거: $composer_remove_repos"
    pct exec "$vmid" -- bash -c "cat > /tmp/_crr.py <<'PYEOF'
import json, os
hosts = [h.strip() for h in os.environ['HOSTS'].split(',') if h.strip()]
path = '$APP_ROOT/composer.json'
data = json.load(open(path))
repos = data.get('repositories', [])
keep = [r for r in repos if not (isinstance(r, dict) and any(h in (r.get('url') or '') for h in hosts))]
data['repositories'] = keep
json.dump(data, open(path,'w'), indent=4)
print('kept repos:', keep)
PYEOF"
    pct exec "$vmid" -- bash -c "HOSTS='$composer_remove_repos' python3 /tmp/_crr.py" >&2
    in_lxc "$vmid" "rm -f $APP_ROOT/composer.lock" >&2
  fi

  # APP_KEY 는 아직 없음 — artisan key:generate 에서 채움.
  # .env 의 DB/APP 관련 값 주입.
  in_lxc "$vmid" "
    cd $APP_ROOT
    sed -i -E \"s|^APP_NAME=.*|APP_NAME='${app_name}'|\"            .env
    sed -i -E \"s|^APP_ENV=.*|APP_ENV=production|\"                  .env
    sed -i -E \"s|^APP_DEBUG=.*|APP_DEBUG=false|\"                   .env
    sed -i -E \"s|^APP_URL=.*|APP_URL=https://${domain}|\"           .env
    sed -i -E \"s|^DB_CONNECTION=.*|DB_CONNECTION=mysql|\"           .env
    sed -i -E \"s|^[# ]*DB_HOST=.*|DB_HOST=127.0.0.1|\"              .env
    sed -i -E \"s|^[# ]*DB_PORT=.*|DB_PORT=3306|\"                   .env
    sed -i -E \"s|^[# ]*DB_DATABASE=.*|DB_DATABASE=${db_name}|\"     .env
    sed -i -E \"s|^[# ]*DB_USERNAME=.*|DB_USERNAME=${db_user}|\"     .env
    sed -i -E \"s|^[# ]*DB_PASSWORD=.*|DB_PASSWORD=${db_password}|\" .env
    # 옵션: 내부 메일 프록시 사용
    sed -i -E \"s|^MAIL_MAILER=.*|MAIL_MAILER=smtp|\"                .env
    sed -i -E \"s|^MAIL_HOST=.*|MAIL_HOST=10.0.50.122|\"             .env
    sed -i -E \"s|^MAIL_PORT=.*|MAIL_PORT=2525|\"                    .env
    grep -qE '^MAIL_ENCRYPTION=' .env && sed -i -E \"s|^MAIL_ENCRYPTION=.*|MAIL_ENCRYPTION=null|\" .env || echo 'MAIL_ENCRYPTION=null' >> .env
  " >&2
  ok "리포 + .env"

  # ── 8. App 셋업 (composer / key / migrate / npm / cache) ────────────────
  log "[8/9] 앱 셋업 (composer install / key:generate / migrate / npm build)"
  _run_setup "$vmid" "$do_npm" "$do_migrate"
  ok "앱 셋업"

  # ── 9. nginx + php-fpm + Traefik 라우트 ─────────────────────────────────
  log "[9/9] nginx + php-fpm vhost + Traefik 라우트"
  _deploy_nginx "$vmid" "$domain" "$php_ver"

  if [[ "$do_traefik" == "yes" ]]; then
    _traefik_register "$vmid" "$hostname" "$domain" "$ip"
  else
    warn "--no-traefik → Traefik 라우트 등록 생략 (수동 pxi-service add)"
  fi

  # 요약 저장
  in_lxc "$vmid" "
    mkdir -p /etc/pxi
    cat > /etc/pxi/laravel.meta <<META
VMID=$vmid
HOSTNAME=$hostname
DOMAIN=$domain
IP=$ip
REPO=$repo
SOURCE_DIR=$source_dir
BRANCH=$branch
INSTALL_MODE=$([[ -n "$source_dir" ]] && echo source-dir || echo repo)
APP_ROOT=$APP_ROOT
PHP_VER=$php_ver
NODE_VER=$node_ver
DB_NAME=$db_name
DB_USER=$db_user
DB_PASSWORD=$db_password
INSTALLED_AT=\$(date -Iseconds)
META
    chmod 600 /etc/pxi/laravel.meta
  " >&2

  echo >&2
  ok "Laravel 배포 완료"
  cat <<EOF >&2

  $(c_green '서비스:') https://$domain
  $(c_green 'SSH 진입:') pct enter $vmid
  $(c_green 'DB 정보:') /etc/pxi/laravel.meta (inside LXC)

  다음 단계 (필요 시):
    pxi-laravel artisan $vmid migrate:status
    pxi-laravel logs    $vmid app
    pxi-laravel doctor  $vmid
EOF
}

_deploy_source_dir() {
  local vmid="$1" source_dir="$2"
  local tarball
  tarball="$(mktemp /tmp/pxi-laravel-src.XXXXXX.tar.gz)"

  tar -C "$source_dir" \
    --exclude=".git" \
    --exclude="vendor" \
    --exclude="node_modules" \
    --exclude=".env" \
    --exclude="database/database.sqlite" \
    --exclude="bootstrap/cache/*.php" \
    -czf "$tarball" .

  pct push "$vmid" "$tarball" /tmp/pxi-laravel-src.tar.gz >/dev/null
  rm -f "$tarball"

  in_lxc "$vmid" "
    tmp_env=\$(mktemp /tmp/pxi-laravel-env.XXXXXX)
    tmp_storage=\$(mktemp -d /tmp/pxi-laravel-storage.XXXXXX)
    if [[ -f $APP_ROOT/.env ]]; then
      cp $APP_ROOT/.env \$tmp_env
    else
      rm -f \$tmp_env
    fi
    if [[ -d $APP_ROOT/storage ]]; then
      cp -a $APP_ROOT/storage/. \$tmp_storage/
    fi
    rm -rf $APP_ROOT
    mkdir -p $APP_ROOT
    tar -xzf /tmp/pxi-laravel-src.tar.gz -C $APP_ROOT
    rm -f /tmp/pxi-laravel-src.tar.gz
    cd $APP_ROOT
    if [[ -f \$tmp_env ]]; then
      cp \$tmp_env .env
      rm -f \$tmp_env
    elif [[ ! -f .env && -f .env.example ]]; then
      cp .env.example .env
    fi
    if [[ -d \$tmp_storage ]]; then
      mkdir -p storage
      cp -a \$tmp_storage/. storage/ 2>/dev/null || true
      rm -rf \$tmp_storage
    fi
  " >&2
}

# ── app setup: composer + key + migrate + npm ──────────────────────────────
_run_setup() {
  local vmid="$1" do_npm="$2" do_migrate="$3"

  # Laravel storage 서브디렉토리 보장 (git 은 이것들을 추적 안 함)
  in_lxc "$vmid" "mkdir -p $APP_ROOT/storage/framework/{cache/data,sessions,views,testing} $APP_ROOT/storage/logs $APP_ROOT/bootstrap/cache" >&2
  in_lxc "$vmid" "
    if [[ -f $APP_ROOT/.env ]]; then
      chown root:www-data $APP_ROOT/.env
      chmod 640 $APP_ROOT/.env
    fi
  " >&2

  in_lxc "$vmid" "cd $APP_ROOT && composer install --no-dev --no-interaction --prefer-dist --optimize-autoloader --no-progress" \
    || die "composer install 실패. pct enter $vmid 로 들어가서 composer.json 확인 후 pxi-laravel setup $vmid 로 재시도"

  in_lxc "$vmid" "cd $APP_ROOT && grep -q '^APP_KEY=base64:' .env || php artisan key:generate --force" >&2

  if [[ "$do_migrate" == "yes" ]]; then
    in_lxc "$vmid" "cd $APP_ROOT && php artisan migrate --force" \
      || warn "migrate 실패 — 로그 확인 필요"
  fi

  if [[ "$do_npm" == "yes" ]]; then
    if in_lxc "$vmid" "test -f $APP_ROOT/package.json"; then
      if in_lxc "$vmid" "test -f $APP_ROOT/package-lock.json"; then
        in_lxc "$vmid" "cd $APP_ROOT && npm ci --no-audit --no-fund" \
          || die "npm ci 실패"
      else
        warn "package-lock.json 없음 — npm install 로 대체"
        in_lxc "$vmid" "cd $APP_ROOT && npm install --no-audit --no-fund" \
          || die "npm install 실패"
      fi
      in_lxc "$vmid" "cd $APP_ROOT && npm run build" \
        || warn "npm run build 실패 — build 스크립트 확인"
    else
      warn "package.json 없음 — npm 단계 생략"
    fi
  fi

  # 캐시 + 심볼릭 링크 + 퍼미션
  in_lxc "$vmid" "
    cd $APP_ROOT
    php artisan storage:link 2>/dev/null || true
    php artisan config:cache 2>/dev/null || true
    php artisan route:cache  2>/dev/null || true
    php artisan view:cache   2>/dev/null || true
    chown -R www-data:www-data $APP_ROOT/storage $APP_ROOT/bootstrap/cache
    find $APP_ROOT/storage -type d -exec chmod 775 {} \\;
    find $APP_ROOT/bootstrap/cache -type d -exec chmod 775 {} \\;
  " >&2
}

# ── nginx vhost ─────────────────────────────────────────────────────────────
_deploy_nginx() {
  local vmid="$1" domain="$2" php_ver="$3"
  in_lxc "$vmid" "
    cat > /etc/nginx/sites-available/laravel <<NGX
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _ $domain;
    root $APP_ROOT/public;
    index index.php index.html;

    add_header X-Frame-Options \"SAMEORIGIN\";
    add_header X-Content-Type-Options \"nosniff\";

    client_max_body_size 50M;

    location / {
        try_files \\\$uri \\\$uri/ /index.php?\\\$query_string;
    }

    location ~ \\.php\$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php${php_ver}-fpm.sock;
        fastcgi_read_timeout 300;
    }

    location ~ /\\.(?!well-known).* { deny all; }
    access_log /var/log/nginx/laravel.access.log;
    error_log  /var/log/nginx/laravel.error.log;
}
NGX
    ln -sf /etc/nginx/sites-available/laravel /etc/nginx/sites-enabled/laravel
    rm -f /etc/nginx/sites-enabled/default
    nginx -t
    systemctl enable --now php${php_ver}-fpm nginx
    systemctl reload nginx
  " >&2
  ok "nginx + php-fpm 활성화"
}

# ── Traefik 라우트 ──────────────────────────────────────────────────────────
_traefik_register() {
  local vmid="$1" name="$2" domain="$3" ip="$4"
  # domain = foo.50.internal.kr → root = 50.internal.kr
  local root_domain
  root_domain="$(echo "$domain" | sed -E 's/^[^.]+\.//')"
  if pxi-service add \
    --domain "$root_domain" \
    --name "$name" \
    --host "$domain" \
    --ip "$ip" \
    --port 80 \
    --vmid "$vmid" >&2; then
    ok "Traefik 라우트 등록: https://$domain → $ip:80"
  else
    warn "pxi-service add 실패 — 수동 등록 필요"
  fi
}

# ── setup (install 후 재셋업) ───────────────────────────────────────────────
cmd_setup() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel setup <vmid>"
  require_laravel "$vmid"
  _run_setup "$vmid" "yes" "yes"
  ok "setup 완료"
}

# ── update (git pull + setup) ──────────────────────────────────────────────
cmd_update() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel update <vmid>"
  require_laravel "$vmid"
  local install_mode source_dir
  install_mode="$(in_lxc "$vmid" "awk -F= '/^INSTALL_MODE=/{print \$2}' /etc/pxi/laravel.meta 2>/dev/null" || true)"
  if [[ "$install_mode" == "source-dir" ]]; then
    source_dir="$(in_lxc "$vmid" "awk -F= '/^SOURCE_DIR=/{print substr(\$0, index(\$0, \"=\")+1)}' /etc/pxi/laravel.meta 2>/dev/null" || true)"
    [[ -n "$source_dir" ]] || die "source-dir 설치지만 SOURCE_DIR 메타가 비어 있음"
    [[ -d "$source_dir" ]] || die "source-dir 경로가 호스트에 없음: $source_dir"
    log "source-dir 동기화: $source_dir"
    in_lxc "$vmid" "cd $APP_ROOT && php artisan down || true" >&2
    _deploy_source_dir "$vmid" "$source_dir"
  else
    log "git pull"
    in_lxc "$vmid" "cd $APP_ROOT && php artisan down || true; git fetch --all && git reset --hard @{u}" >&2
  fi
  _run_setup "$vmid" "yes" "yes"
  in_lxc "$vmid" "cd $APP_ROOT && php artisan up || true; systemctl reload php*-fpm nginx || true" >&2
  ok "update 완료"
}

cmd_artisan() {
  local vmid="${1:-}"; shift || true
  [[ -n "$vmid" ]] || die "사용법: pxi-laravel artisan <vmid> <artisan args...>"
  require_laravel "$vmid"

  # 각 arg 를 printf %q 로 쉘 안전 quote (공백·세미콜론·백틱 방어)
  local quoted_args=""
  local a
  for a in "$@"; do
    quoted_args+=" $(printf '%q' "$a")"
  done

  if _env_is_encrypted "$vmid"; then
    # 암호화 상태 — decrypt 서비스가 생성한 /run/pxi-laravel-<vmid>.env 를 source
    # (FPM 과 동일한 env 를 CLI 에도 주입)
    in_lxc "$vmid" "
      RUN_ENV=/run/pxi-laravel-$vmid.env
      [[ -f \$RUN_ENV ]] || { systemctl start pxi-laravel-decrypt@$vmid.service; sleep 1; }
      cd $APP_ROOT && set -a && . \$RUN_ENV && set +a && php artisan$quoted_args
    "
  else
    in_lxc "$vmid" "cd $APP_ROOT && php artisan$quoted_args"
  fi
}

cmd_logs() {
  local vmid="${1:-}" kind="${2:-app}"
  [[ -n "$vmid" ]] || die "사용법: pxi-laravel logs <vmid> [app|nginx|php|error]"
  require_laravel "$vmid"
  case "$kind" in
    app)    in_lxc "$vmid" "tail -n 200 $APP_ROOT/storage/logs/laravel.log 2>/dev/null || echo '(no laravel.log yet)'" ;;
    nginx)  in_lxc "$vmid" "tail -n 200 /var/log/nginx/laravel.access.log 2>/dev/null" ;;
    error)  in_lxc "$vmid" "tail -n 200 /var/log/nginx/laravel.error.log 2>/dev/null" ;;
    php)    in_lxc "$vmid" "journalctl -u 'php*-fpm' -n 200 --no-pager" ;;
    *) die "kind: app|nginx|php|error" ;;
  esac
}

cmd_status() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel status <vmid>"
  require_laravel "$vmid"
  echo "== LXC =="; pct status "$vmid"; pct config "$vmid" | grep -E '^(hostname|tags|net0|memory|cores):'
  echo; echo "== Services =="
  in_lxc "$vmid" "systemctl is-active mariadb nginx php*-fpm 2>&1 | head"
  echo; echo "== App =="
  in_lxc "$vmid" "cd $APP_ROOT && php artisan --version && php artisan about 2>/dev/null | head -40 || true"
}

cmd_doctor() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel doctor <vmid>"
  require_laravel "$vmid"
  local ip; ip="$(lxc_ip "$vmid")"
  echo "IP: $ip"
  echo -n "HTTP 80: "; curl -sk -o /dev/null -w "%{http_code}\n" "http://${ip}/" --max-time 5 || true
  echo "services:"
  in_lxc "$vmid" "for s in mariadb nginx php8.2-fpm php8.3-fpm php8.4-fpm; do
    systemctl is-enabled \$s 2>/dev/null >/dev/null && printf '  %-18s %s\n' \$s \$(systemctl is-active \$s)
  done"
  echo "DB:"
  in_lxc "$vmid" "mariadb -e 'SELECT table_schema, COUNT(*) AS tables FROM information_schema.tables WHERE table_schema NOT IN (\"mysql\",\"information_schema\",\"performance_schema\",\"sys\") GROUP BY table_schema;'"
  echo "Storage perms:"
  in_lxc "$vmid" "stat -c '%a %U:%G %n' $APP_ROOT/storage $APP_ROOT/bootstrap/cache 2>/dev/null"
}

# ── dotenvx 감지/헬퍼 ────────────────────────────────────────────────────────
# .env 가 dotenvx 로 암호화된 상태인지 판정 (첫 줄에 DOTENV_PUBLIC_KEY 가 있으면 암호화)
_env_is_encrypted() {
  local vmid="$1"
  in_lxc "$vmid" "head -5 $APP_ROOT/.env 2>/dev/null | grep -q '^DOTENV_PUBLIC_KEY='"
}

# php-fpm 버전 (8.4/8.3/8.2 중 활성) 감지
_fpm_version() {
  local vmid="$1"
  in_lxc "$vmid" "for v in 8.4 8.3 8.2; do
    systemctl is-active php\$v-fpm >/dev/null 2>&1 && { echo \$v; exit 0; }
  done; exit 1"
}

cmd_env_show() {
  local vmid="${1:-}"; shift || true
  [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-show <vmid> [--decrypt]"
  require_laravel "$vmid"
  local decrypt="no"
  [[ "${1:-}" == "--decrypt" ]] && decrypt="yes"

  if _env_is_encrypted "$vmid"; then
    if [[ "$decrypt" == "yes" ]]; then
      # decrypt 서비스가 생성한 /run tmpfs 파일을 그대로 출력
      in_lxc "$vmid" "
        RUN_ENV=/run/pxi-laravel-$vmid.env
        [[ -f \$RUN_ENV ]] || { systemctl start pxi-laravel-decrypt@$vmid.service >/dev/null 2>&1; sleep 1; }
        [[ -f \$RUN_ENV ]] || { echo '(decrypt 서비스 실행 실패 — env-keys-install 먼저)' >&2; exit 1; }
        cat \$RUN_ENV
      "
    else
      warn ".env 는 dotenvx 로 암호화되어 있습니다 (--decrypt 로 복호화 보기)"
      in_lxc "$vmid" "cat $APP_ROOT/.env"
    fi
  else
    in_lxc "$vmid" "cat $APP_ROOT/.env"
  fi
}

cmd_env_edit() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-edit <vmid>"
  require_laravel "$vmid"

  if _env_is_encrypted "$vmid"; then
    warn ".env 가 암호화 상태입니다. 대신 다음을 사용하세요:"
    warn "  pxi-laravel env-reencrypt $vmid     # 복호화 → 편집 → 재암호화 원샷"
    die "편집 차단 — 암호화된 파일을 직접 편집하면 키가 깨집니다"
  fi

  pct exec "$vmid" -- ${EDITOR:-nano} "$APP_ROOT/.env"
  in_lxc "$vmid" "cd $APP_ROOT && php artisan config:clear && php artisan config:cache" >&2
  ok ".env 저장 + config 캐시 재생성"
}

# ── dotenvx 정본 키 저장소 (호스트) ──────────────────────────────────────────
# 피드백 feedback_not_root_only.md 준수: /root/control-plane 이 정본,
# /etc/pxi (proxmox-init) 는 동기화 대상. 개별 /root/.secrets 는 root 단독
# 금지라 쓰지 않음.
PXI_LARAVEL_SECRETS_DIR="/root/control-plane/.secrets/pxi-laravel"

# dotenvx 버전 고정 (W3: supply chain 방어). 업그레이드 시 이 값만 수정.
DOTENVX_VERSION="1.61.1"
DOTENVX_INSTALL_URL="https://dotenvx.sh/${DOTENVX_VERSION}"

# LXC 안에 dotenvx 설치 (이미 해당 버전이면 skip)
_install_dotenvx() {
  local vmid="$1"
  in_lxc "$vmid" "
    if command -v dotenvx >/dev/null 2>&1; then
      INSTALLED=\$(/usr/local/bin/dotenvx --version 2>/dev/null || echo unknown)
      if [[ \"\$INSTALLED\" == \"$DOTENVX_VERSION\" ]]; then
        exit 0
      fi
    fi
    curl -fsSL $DOTENVX_INSTALL_URL | VERSION=$DOTENVX_VERSION sh
  " >&2
}

_keys_path() { echo "$PXI_LARAVEL_SECRETS_DIR/${1}.env.keys"; }

# LXC 안에 decrypt helper + oneshot 서비스 template 설치
_install_decrypt_infra() {
  local vmid="$1"
  # 1) helper script
  in_lxc "$vmid" "cat > /usr/local/bin/pxi-env-decrypt <<'DEC_EOF'
#!/bin/bash
set -eu
SRC=\"\$1\"
DST=\"\$2\"
cp \"\$SRC\" \"\$DST\"
/usr/local/bin/dotenvx decrypt -f \"\$DST\"
chmod 600 \"\$DST\"
DEC_EOF
chmod +x /usr/local/bin/pxi-env-decrypt"

  # 2) oneshot service template (instance name = vmid)
  in_lxc "$vmid" "cat > /etc/systemd/system/pxi-laravel-decrypt@.service <<UNIT_EOF
[Unit]
Description=pxi-laravel dotenvx decrypt for LXC %i
Before=php8.2-fpm.service php8.3-fpm.service php8.4-fpm.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/pxi-env-decrypt $APP_ROOT/.env /run/pxi-laravel-%i.env
UNIT_EOF"
}

# ── env-encrypt: 평문 .env → 암호화 + keys 를 호스트 정본 위치로 ──────────
cmd_env_encrypt() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-encrypt <vmid>"
  require_laravel "$vmid"

  if _env_is_encrypted "$vmid"; then
    ok ".env 가 이미 암호화 상태입니다. env-keys-install 로 이동."
    return 0
  fi

  log "dotenvx 바이너리 LXC 에 설치"
  _install_dotenvx "$vmid"

  log ".env 암호화 (dotenvx encrypt)"
  in_lxc "$vmid" "cd $APP_ROOT && dotenvx encrypt -f .env" >&2

  local kpath; kpath="$(_keys_path "$vmid")"
  mkdir -p "$(dirname "$kpath")"
  chmod 700 "$(dirname "$kpath")"
  log "키 파일을 호스트 정본 위치로 이동: $kpath"
  pct pull "$vmid" "$APP_ROOT/.env.keys" "$kpath" >&2
  chmod 600 "$kpath"
  in_lxc "$vmid" "rm -f $APP_ROOT/.env.keys" >&2  # LXC 에는 키 남기지 않음

  ok "env-encrypt 완료. 이제 'pxi-laravel env-keys-install $vmid' 로 systemd 설정하세요."
}

# ── env-keys-install: 정본 키 + systemd override 설치 ────────────────────
# W1: 기존 설치 감지 시 skip / key drift 시만 갱신
# W2: 실패 시 자동 rollback (override·drop-in 제거 후 원래 서비스 복구)
cmd_env_keys_install() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-keys-install <vmid>"
  require_laravel "$vmid"

  _env_is_encrypted "$vmid" \
    || die ".env 가 평문 상태. 먼저 'pxi-laravel env-encrypt $vmid' 실행"

  local kpath; kpath="$(_keys_path "$vmid")"
  [[ -f "$kpath" ]] || die "정본 키 없음: $kpath — env-encrypt 나 env-keys-backup 으로 확보"

  local pkey
  pkey="$(grep '^DOTENV_PRIVATE_KEY=' "$kpath" | head -1 | cut -d= -f2- | tr -d '"')"
  [[ -n "$pkey" ]] || die "DOTENV_PRIVATE_KEY 가 비어있음"

  local fpm_ver; fpm_ver="$(_fpm_version "$vmid")" || die "php-fpm 활성 버전 감지 실패"
  log "감지된 php-fpm 버전: $fpm_ver"

  # W1: idempotent — 기존 설치 + 동일 key 이면 skip
  local installed_pkey
  installed_pkey="$(in_lxc "$vmid" "grep -h '^Environment=' /etc/systemd/system/pxi-laravel-decrypt@$vmid.service.d/*.conf 2>/dev/null | sed 's/.*DOTENV_PRIVATE_KEY=//; s/\"//g' | head -1" || true)"
  if [[ "$installed_pkey" == "$pkey" ]] \
     && in_lxc "$vmid" "test -f /etc/systemd/system/php$fpm_ver-fpm.service.d/dotenvx.conf" \
     && in_lxc "$vmid" "systemctl is-active php$fpm_ver-fpm" | grep -q active; then
    ok "이미 동일 키로 설치됨. skip. (fingerprint $(sha256sum "$kpath" | cut -c1-8))"
    return 0
  fi

  _install_dotenvx "$vmid"
  _install_decrypt_infra "$vmid"

  log "php-fpm pool: clear_env = no"
  in_lxc "$vmid" "
    POOL=/etc/php/$fpm_ver/fpm/pool.d/www.conf
    grep -q '^clear_env' \"\$POOL\" \
      && sed -i 's|^;\\?clear_env.*|clear_env = no|' \"\$POOL\" \
      || echo 'clear_env = no' >> \"\$POOL\"
  " >&2

  # W2: rollback 스냅샷 (이전 override·drop-in 백업)
  local backup_tag; backup_tag="/tmp/pxi-laravel-rb-$$-$(date +%s)"
  in_lxc "$vmid" "
    mkdir -p $backup_tag
    cp -a /etc/systemd/system/php$fpm_ver-fpm.service.d $backup_tag/fpm-drop-in 2>/dev/null || :
    cp -a /etc/systemd/system/pxi-laravel-decrypt@$vmid.service.d $backup_tag/decrypt-drop-in 2>/dev/null || :
  " >&2

  _env_keys_install_rollback() {
    warn "rollback 실행 중… (백업: $backup_tag)"
    in_lxc "$vmid" "
      rm -rf /etc/systemd/system/php$fpm_ver-fpm.service.d /etc/systemd/system/pxi-laravel-decrypt@$vmid.service.d
      [ -d $backup_tag/fpm-drop-in ] && cp -a $backup_tag/fpm-drop-in /etc/systemd/system/php$fpm_ver-fpm.service.d
      [ -d $backup_tag/decrypt-drop-in ] && cp -a $backup_tag/decrypt-drop-in /etc/systemd/system/pxi-laravel-decrypt@$vmid.service.d
      systemctl daemon-reload
      systemctl restart php$fpm_ver-fpm
    " >&2 || warn "rollback 도 실패 — 수동 확인 필요: journalctl -u php$fpm_ver-fpm"
  }

  # systemd override: decrypt service dependency + EnvironmentFile
  log "systemd override: php$fpm_ver-fpm → decrypt@$vmid dependency + EnvironmentFile"
  if ! in_lxc "$vmid" "
    OVERRIDE_DIR=/etc/systemd/system/php$fpm_ver-fpm.service.d
    mkdir -p \"\$OVERRIDE_DIR\"
    cat > \"\$OVERRIDE_DIR/dotenvx.conf\" <<EOF
[Unit]
Wants=pxi-laravel-decrypt@$vmid.service
After=pxi-laravel-decrypt@$vmid.service

[Service]
EnvironmentFile=/run/pxi-laravel-$vmid.env
EOF
    chmod 600 \"\$OVERRIDE_DIR/dotenvx.conf\"

    # decrypt service 에 DOTENV_PRIVATE_KEY 주입 (드롭인)
    DROP_DIR=/etc/systemd/system/pxi-laravel-decrypt@$vmid.service.d
    mkdir -p \"\$DROP_DIR\"
    cat > \"\$DROP_DIR/key.conf\" <<EOF
[Service]
Environment=\"DOTENV_PRIVATE_KEY=$pkey\"
EOF
    chmod 600 \"\$DROP_DIR/key.conf\"

    systemctl daemon-reload
    systemctl enable pxi-laravel-decrypt@$vmid.service >/dev/null 2>&1 || true
    systemctl restart pxi-laravel-decrypt@$vmid.service
    systemctl restart php$fpm_ver-fpm
  " >&2; then
    _env_keys_install_rollback
    die "systemd 적용 실패 — rollback 완료"
  fi

  sleep 2
  if ! in_lxc "$vmid" "systemctl is-active php$fpm_ver-fpm" | grep -q active; then
    _env_keys_install_rollback
    die "php$fpm_ver-fpm 재시작 실패 — rollback 완료. journalctl -u php$fpm_ver-fpm 확인"
  fi

  # 성공 — 백업 정리
  in_lxc "$vmid" "rm -rf $backup_tag" >&2 || :

  ok "env-keys-install 완료"
  log "fingerprint: $(sha256sum "$kpath" | cut -c1-8)"
}

# ── env-reencrypt: 복호화 → 편집 → 재암호화 원샷 ─────────────────────────
# 암호화된 .env 를 안전하게 편집. 키 rotate 가 일어나면 호스트 정본도 갱신.
cmd_env_reencrypt() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-reencrypt <vmid>"
  require_laravel "$vmid"

  _env_is_encrypted "$vmid" \
    || die ".env 가 평문 상태. env-edit 를 쓰세요"

  local kpath; kpath="$(_keys_path "$vmid")"
  [[ -f "$kpath" ]] || die "정본 키 없음: $kpath"

  local pkey
  pkey="$(grep '^DOTENV_PRIVATE_KEY=' "$kpath" | head -1 | cut -d= -f2- | tr -d '"')"
  [[ -n "$pkey" ]] || die "DOTENV_PRIVATE_KEY 비어있음"

  local tmp="/tmp/pxi-laravel-edit-${vmid}-$$.env"

  # LXC 에 임시 평문 준비 (cleanup trap)
  in_lxc "$vmid" "
    cp $APP_ROOT/.env $tmp
    DOTENV_PRIVATE_KEY=$(printf '%q' "$pkey") /usr/local/bin/dotenvx decrypt -f $tmp >/dev/null
    chmod 600 $tmp
  " >&2

  # 편집자 열기 (블로킹)
  log "편집자 열림: $tmp"
  pct exec "$vmid" -- "${EDITOR:-nano}" "$tmp"

  # 편집본 검증 — dotenvx 가 파싱 가능한지
  in_lxc "$vmid" "/usr/local/bin/dotenvx run --env-file=$tmp -- true >/dev/null 2>&1" \
    || { in_lxc "$vmid" "rm -f $tmp" >&2; die "편집본 파싱 실패 — 편집 취소됨"; }

  # 기존 암호화본 백업 → 재암호화 → 성공 시 덮어쓰기
  local old_fingerprint="$(sha256sum "$kpath" | cut -c1-8)"
  in_lxc "$vmid" "
    cp $APP_ROOT/.env $APP_ROOT/.env.pre-reencrypt
    cp $tmp $APP_ROOT/.env
    rm -f $APP_ROOT/.env.keys
    /usr/local/bin/dotenvx encrypt -f $APP_ROOT/.env >/dev/null
    rm -f $tmp
  " >&2 || die "재암호화 실패"

  # 키 rotate 감지 (dotenvx 는 기존 public key 가 있으면 유지, 없으면 새로 생성)
  local new_pkey
  new_pkey="$(in_lxc "$vmid" "grep '^DOTENV_PRIVATE_KEY=' $APP_ROOT/.env.keys 2>/dev/null | cut -d= -f2- | tr -d '\"'")"

  if [[ "$new_pkey" != "$pkey" ]]; then
    warn "키가 rotate 되었습니다 (이전 $old_fingerprint → 신규)"
    pct pull "$vmid" "$APP_ROOT/.env.keys" "$kpath" >&2
    chmod 600 "$kpath"
    in_lxc "$vmid" "rm -f $APP_ROOT/.env.keys" >&2
    warn "systemd drop-in 갱신 필요: pxi-laravel env-keys-install $vmid"
  else
    # 키 동일 — LXC 의 .env.keys 는 보안상 제거
    in_lxc "$vmid" "rm -f $APP_ROOT/.env.keys" >&2
  fi

  # decrypt 서비스 재시작 → /run tmpfs 갱신 → php-fpm reload
  local fpm_ver; fpm_ver="$(_fpm_version "$vmid")"
  in_lxc "$vmid" "
    systemctl restart pxi-laravel-decrypt@$vmid.service
    systemctl reload php$fpm_ver-fpm
    rm -f $APP_ROOT/.env.pre-reencrypt
  " >&2

  ok "env-reencrypt 완료"
}

# ── env-keys-backup: LXC → 호스트 정본 (긴급 복구) ──────────────────────
cmd_env_keys_backup() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-keys-backup <vmid>"
  require_laravel "$vmid"

  in_lxc "$vmid" "[ -f $APP_ROOT/.env.keys ]" \
    || die "LXC 에 .env.keys 없음 — 이미 systemd Environment 로만 관리 중일 가능성"

  local kpath; kpath="$(_keys_path "$vmid")"
  mkdir -p "$(dirname "$kpath")"; chmod 700 "$(dirname "$kpath")"
  pct pull "$vmid" "$APP_ROOT/.env.keys" "$kpath" >&2
  chmod 600 "$kpath"
  ok "백업: $kpath"
}

# ── env-keys-fingerprint: 호스트 정본 키 지문 (rotate 확인용) ──────────
cmd_env_keys_fingerprint() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel env-keys-fingerprint <vmid>"
  local kpath; kpath="$(_keys_path "$vmid")"
  [[ -f "$kpath" ]] || die "정본 키 없음: $kpath"
  echo "fingerprint: $(sha256sum "$kpath" | cut -c1-8)"
  echo "path:        $kpath"
}

cmd_db() {
  local vmid="${1:-}"; shift || true
  [[ -n "$vmid" ]] || die "사용법: pxi-laravel db <vmid> [client|dump|mariadb args...]"
  require_laravel "$vmid"
  local action="${1:-client}"; shift || true
  case "$action" in
    client|mariadb)
      pct exec "$vmid" -- mariadb "$@"
      ;;
    dump)
      local name; name="$(in_lxc "$vmid" "grep ^DB_DATABASE= /etc/pxi/laravel.meta | cut -d= -f2")" || name=""
      [[ -n "$name" ]] || name="$(in_lxc "$vmid" "grep ^DB_DATABASE= $APP_ROOT/.env | cut -d= -f2")"
      local ts; ts="$(date +%Y%m%d-%H%M%S)"
      in_lxc "$vmid" "mariadb-dump --single-transaction --quick '$name' | gzip -c > /root/${name}-${ts}.sql.gz && ls -lh /root/${name}-${ts}.sql.gz"
      ;;
    *) die "db action: client|dump" ;;
  esac
}

cmd_delete() {
  local vmid="${1:-}"; [[ -n "$vmid" ]] || die "사용법: pxi-laravel delete <vmid>"
  require_laravel "$vmid"
  local domain; domain="$(in_lxc "$vmid" "grep ^DOMAIN= /etc/pxi/laravel.meta | cut -d= -f2" 2>/dev/null || true)"
  local hostname; hostname="$(pct config "$vmid" | awk '/^hostname:/{print $2}')"
  warn "LXC $vmid ($hostname / $domain) 삭제 — 10초 내 Ctrl-C"
  sleep 10
  if [[ -n "$domain" ]]; then
    local root_domain; root_domain="$(echo "$domain" | sed -E 's/^[^.]+\.//')"
    pxi-service remove --domain "$root_domain" --name "$hostname" 2>/dev/null || \
      pxi-service remove --domain "$root_domain" --host "$domain" 2>/dev/null || \
      warn "Traefik 라우트 자동 제거 실패 — 수동: pxi-service remove"
  fi
  pct stop "$vmid" 2>/dev/null || true
  pct destroy "$vmid" --purge --force 2>/dev/null
  ok "삭제 완료"
}

cmd_list() {
  printf '%-7s %-20s %-34s %s\n' VMID HOSTNAME DOMAIN IP
  for v in $(pct list | awk 'NR>1 {print $1}'); do
    pct config "$v" 2>/dev/null | grep -qE "^tags:.*\b${TAG}\b" || continue
    local h d i
    h="$(pct config "$v" | awk '/^hostname:/{print $2}')"
    i="$(pct config "$v" | grep -oP 'ip=\K[0-9.]+' | head -1)"
    d="$(in_lxc "$v" 'grep ^DOMAIN= /etc/pxi/laravel.meta 2>/dev/null | cut -d= -f2' 2>/dev/null || echo '')"
    printf '%-7s %-20s %-34s %s\n' "$v" "$h" "$d" "$i"
  done
}

usage() {
  cat <<EOF
pxi-laravel — 자체 호스팅 Laravel LXC 관리

Usage:
  pxi-laravel install  --vmid N --hostname HN --domain D --repo URL [opts]
  pxi-laravel setup    <vmid>                         # composer/npm/migrate/cache 재실행
  pxi-laravel update   <vmid>                         # git pull + setup + reload
  pxi-laravel artisan  <vmid> <args...>               # php artisan pass-through
  pxi-laravel logs     <vmid> [app|nginx|php|error]
  pxi-laravel status   <vmid>
  pxi-laravel doctor   <vmid>
  pxi-laravel env-show <vmid> [--decrypt]         # --decrypt: dotenvx 암호화 시 복호화 출력
  pxi-laravel env-edit <vmid>                     # 평문 .env 편집 (암호화 상태엔 차단)
  pxi-laravel env-encrypt <vmid>                  # 평문 .env → 암호화 + 정본 keys 호스트로 이동
  pxi-laravel env-keys-install <vmid>             # 정본 keys 로 systemd override 설치
  pxi-laravel env-keys-backup <vmid>              # LXC → 호스트 정본 긴급 복구
  pxi-laravel env-keys-fingerprint <vmid>         # 정본 keys 의 sha256 (8자) 지문
  pxi-laravel env-reencrypt <vmid>                # 복호화 → 편집 → 재암호화 원샷
  pxi-laravel db       <vmid> [client|dump]
  pxi-laravel delete   <vmid>
  pxi-laravel list

install 상세:  pxi-laravel install --help
EOF
}

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    install)  cmd_install "$@" ;;
    setup)    cmd_setup "$@" ;;
    update)   cmd_update "$@" ;;
    artisan)  cmd_artisan "$@" ;;
    logs)     cmd_logs "$@" ;;
    status)   cmd_status "$@" ;;
    doctor)   cmd_doctor "$@" ;;
    env-show) cmd_env_show "$@" ;;
    env-edit) cmd_env_edit "$@" ;;
    env-encrypt)          cmd_env_encrypt "$@" ;;
    env-keys-install)     cmd_env_keys_install "$@" ;;
    env-keys-backup)      cmd_env_keys_backup "$@" ;;
    env-keys-fingerprint) cmd_env_keys_fingerprint "$@" ;;
    env-reencrypt)        cmd_env_reencrypt "$@" ;;
    env-init)
      warn "env-init 은 제거되었습니다. 대신 'env-encrypt' 와 'env-keys-install' 을 순서대로 사용하세요."
      exit 2
      ;;
    db)       cmd_db "$@" ;;
    delete)   cmd_delete "$@" ;;
    list)     cmd_list "$@" ;;
    help|--help|-h) usage ;;
    *) usage; die "알 수 없는 커맨드: $cmd" ;;
  esac
}

main "$@"
