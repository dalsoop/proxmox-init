let { Domain } = import "../../../ncl/contracts/domain.ncl" in

{
  name = "chrome-browser-dev",
  description = "Chromium/Helium 브라우저 빌드 LXC와 캐시 관리",
  tags = { product = 'devops, layer = 'remote, platform = 'proxmox },
  requires = [ "lxc" ],
  provides = [
    "chrome-browser-dev create",
    "chrome-browser-dev provision",
    "chrome-browser-dev clone",
    "chrome-browser-dev setup",
    "chrome-browser-dev build-start",
    "chrome-browser-dev build-status",
    "chrome-browser-dev version",
    "chrome-browser-dev paths",
    "chrome-browser-dev run",
    "chrome-browser-dev driver-version",
    "chrome-browser-dev driver-start",
    "chrome-browser-dev logs",
    "chrome-browser-dev snapshot-base",
    "chrome-browser-dev init-workspace",
    "chrome-browser-dev workflow-new",
    "chrome-browser-dev workflow-list",
    "chrome-browser-dev workflow-show",
    "chrome-browser-dev workflow-check",
    "chrome-browser-dev card-assumptions",
    "chrome-browser-dev card-check",
    "chrome-browser-dev profile-show",
    "chrome-browser-dev check",
    "chrome-browser-dev gitlab-setup",
    "chrome-browser-dev x11-setup",
    "chrome-browser-dev x11-simulate",
    "chrome-browser-dev doctor",
  ],
} | Domain
